@{
    ViewData["Title"] = "Şifre Sıfırlama Talebi";
    Layout = "_Layout";
    var resetLink = TempData["ResetLink"] as string;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="display-6 fw-bold text-primary mb-1">DP</div>
                        <h1 class="h4 mb-1">Talebiniz Alındı</h1>
                    </div>

                    <div class="alert alert-info small mb-0">
                        E-posta adresiniz sistemde kayıtlıysa şifre sıfırlama talimatları gönderilecektir.
                        Lütfen gelen kutunuzu kontrol edin.
                    </div>

                    @if (!string.IsNullOrWhiteSpace(resetLink))
                    {
                        <div class="alert alert-warning small mt-3 mb-0">
                            <strong>Development / MVP:</strong> E-posta gönderimi bu ortamda devre dışıdır.
                            Aşağıdaki bağlantıyı kullanarak şifrenizi sıfırlayabilirsiniz.
                            <div class="mt-2">
                                <a href="@resetLink" class="text-break">@resetLink</a>
                            </div>
                        </div>
                    }

                    <p class="text-center text-muted small mt-4 mb-0">
                        <a asp-action="Login" class="text-decoration-none">Giriş sayfasına dön</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
