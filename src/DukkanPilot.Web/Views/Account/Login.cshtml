@model LoginViewModel
@{
    ViewData["Title"] = "Giriş";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="display-6 fw-bold text-primary mb-1">DP</div>
                        <h1 class="h4 mb-1">DükkanPilot</h1>
                        <p class="text-muted small mb-0">Hesabınıza giriş yapın</p>
                    </div>

                    @if (TempData["Success"] is string successMessage)
                    {
                        <div class="alert alert-success small" role="alert">@successMessage</div>
                    }

                    @if (TempData["Error"] is string errorMessage)
                    {
                        <div class="alert alert-danger small" role="alert">@errorMessage</div>
                    }

                    <form asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        @if (ViewData["ReturnUrl"] is string returnUrl && !string.IsNullOrWhiteSpace(returnUrl))
                        {
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                        }
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" autocomplete="username" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" autocomplete="current-password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="text-end mb-3">
                            <a asp-action="ForgotPassword" class="small text-decoration-none">Şifrenizi mi unuttunuz?</a>
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Giriş Yap</button>
                    </form>

                    <p class="text-center text-muted small mt-4 mb-0">
                        Hesabınız yok mu?
                        <a asp-action="Register" class="text-decoration-none">İşletmenizi kaydedin</a>
                    </p>

                    <div class="alert alert-light border small mt-4 mb-0">
                        <strong>Demo hesaplar</strong>
                        <div class="mt-2">
                            Admin: <code>admin@dukkanpilot.local</code> / <code>Admin123!</code>
                        </div>
                        <div class="mt-1">
                            İşletme: <code>owner@dukkanpilot.local</code> / <code>Owner123!</code>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
