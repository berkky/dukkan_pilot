@using DukkanPilot.Core.Enums
@{
    ViewData["Title"] = "Erişim Reddedildi";
    Layout = "_Layout";
    var isSuperAdmin = User.IsInRole(nameof(UserRole.SuperAdmin));
    var isBusinessUser = User.IsInRole(nameof(UserRole.BusinessOwner)) || User.IsInRole(nameof(UserRole.Staff));
    var returnUrl = ViewData["ReturnUrl"] as string
        ?? Context.Request.Query["ReturnUrl"].ToString();
    var isAdminTarget = !string.IsNullOrWhiteSpace(returnUrl)
        && returnUrl.StartsWith("/Admin", StringComparison.OrdinalIgnoreCase);
    var isOwnerOnlyBusinessTarget = !string.IsNullOrWhiteSpace(returnUrl)
        && (returnUrl.Contains("/Business/Staff", StringComparison.OrdinalIgnoreCase)
            || returnUrl.Contains("/Business/Settings", StringComparison.OrdinalIgnoreCase)
            || returnUrl.Contains("/Business/Billing", StringComparison.OrdinalIgnoreCase));
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<section class="landing-page-hero py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">
                <div class="landing-section-card p-4 p-md-5 text-center">
                    <div class="display-6 fw-bold text-warning mb-2">403</div>
                    <h1 class="h4 fw-bold mb-3">Erişim Reddedildi</h1>
                    <p class="text-muted mb-4">
                        @if (!isAuthenticated)
                        {
                            <text>Bu sayfaya erişmek için giriş yapmanız gerekir.</text>
                        }
                        else if (isAdminTarget)
                        {
                            <text>Bu sayfa SuperAdmin yetkisi gerektiriyor olabilir.</text>
                        }
                        else if (isBusinessUser && isOwnerOnlyBusinessTarget)
                        {
                            <text>Bu işlem Owner yetkisi gerektiriyor olabilir.</text>
                        }
                        else
                        {
                            <text>Bu sayfaya erişim yetkiniz bulunmuyor.</text>
                        }
                    </p>
                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        @if (isSuperAdmin)
                        {
                            <a href="/Admin/Dashboard" class="btn btn-primary">Admin Paneli</a>
                        }
                        else if (isBusinessUser)
                        {
                            <a href="/Business/Dashboard" class="btn btn-primary">İşletme Paneli</a>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-primary">Giriş Yap</a>
                        }
                        <a href="/" class="btn btn-outline-secondary">Ana Sayfa</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
