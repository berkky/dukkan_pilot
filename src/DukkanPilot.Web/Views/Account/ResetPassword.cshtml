@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Şifre Sıfırla";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="display-6 fw-bold text-primary mb-1">DP</div>
                        <h1 class="h4 mb-1">Yeni Şifre Belirle</h1>
                        <p class="text-muted small mb-0">Hesabınız için yeni bir şifre oluşturun.</p>
                    </div>

                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="Token" />
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label">E-posta</label>
                            <div class="form-control-plaintext border rounded px-3 py-2 bg-light">@Model.Email</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Şifreyi Güncelle</button>
                    </form>

                    <p class="text-center text-muted small mt-4 mb-0">
                        <a asp-action="ForgotPassword" class="text-decoration-none">Yeni sıfırlama talebi oluştur</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
