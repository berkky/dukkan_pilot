@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <div class="display-6 fw-bold text-primary mb-1">DP</div>
                        <h1 class="h4 mb-1">Şifremi Unuttum</h1>
                        <p class="text-muted small mb-0">E-posta adresinizi girin, size şifre sıfırlama bağlantısı gönderelim.</p>
                    </div>

                    @if (TempData["Error"] is string errorMessage)
                    {
                        <div class="alert alert-danger small" role="alert">@errorMessage</div>
                    }

                    <form asp-action="ForgotPassword" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" autocomplete="username" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Sıfırlama Bağlantısı Gönder</button>
                    </form>

                    <p class="text-center text-muted small mt-4 mb-0">
                        <a asp-action="Login" class="text-decoration-none">Giriş sayfasına dön</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
