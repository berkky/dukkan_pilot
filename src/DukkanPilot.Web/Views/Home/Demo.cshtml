@model DemoPageViewModel
@{
    ViewData["Title"] = "Demo";
    var cta = Model.AuthCta;
}

<section class="landing-page-hero py-5">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <span class="landing-pill landing-pill-dark mb-3">Satış demosu</span>
                <h1 class="display-6 fw-bold mb-3">DukkanPilot’u 5 dakikada deneyin</h1>
                <p class="text-muted mb-0">
                    Public demo menü login istemez. Panel deneyimi için giriş yapın veya kendi işletmenizi oluşturun.
                    Demo hesap şifreleri bu sayfada paylaşılmaz.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <div class="row g-4 mb-4">
            <div class="col-lg-5">
                <div class="landing-demo-card h-100">
                    <div class="landing-pill landing-pill-dark mb-3">Public demo</div>
                    <h2 class="h4">@Model.DemoBusinessName</h2>
                    <p class="text-muted">QR menü + sepet + kampanya + sipariş takip akışı.</p>
                    <code class="landing-code d-block mb-3">@Model.DemoMenuUrl</code>
                    <div class="d-grid gap-2">
                        <a href="@Model.DemoMenuUrl" class="btn btn-success btn-lg" target="_blank" rel="noopener">Demo QR Menüyü Aç</a>
                        <a href="/Sales/RequestDemo" class="btn btn-outline-primary">Demo talep et</a>
                        <a href="/RoiCalculator" class="btn btn-outline-primary">Önce değerini hesapla</a>
                        <a href="/Account/Login" class="btn btn-outline-secondary">İşletme Panelini İncele</a>
                        <a href="/Account/Register" class="btn btn-primary">Kendi işletmeniz için ücretsiz başlayın</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="landing-section-card h-100">
                    <h2 class="h5 mb-3">Demo akışı</h2>
                    <ol class="landing-demo-steps mb-0">
                        <li><strong>QR menüyü aç</strong><span>@Model.DemoMenuUrl adresini açın.</span></li>
                        <li><strong>Sepete ürün ekle</strong><span>Ürün kartından sepete ekleyip özeti kontrol edin.</span></li>
                        <li><strong>Kampanya indirimini gör</strong><span>100₺ üzeri sepette otomatik indirim mesajını görün.</span></li>
                        <li><strong>Sipariş oluştur</strong><span>Confirmation ekranı + WhatsApp mesaj özeti.</span></li>
                        <li><strong>Sipariş takip ekranı</strong><span>Badge, timeline ve durum güncellemesini izleyin.</span></li>
                        <li><strong>İşletme panelinde yönet</strong><span>Sipariş / Mutfak / CRM / Raporlar için panele giriş gerekir.</span></li>
                    </ol>
                </div>
            </div>
        </div>

        <div class="text-center mb-3">
            <h2 class="h4 fw-bold">Özellik vitrini</h2>
            <p class="text-muted">Demo sırasında vurgulanacak modüller</p>
        </div>
        <div class="row g-3 mb-4">
            @foreach (var item in new[] {
                ("📱", "QR Menü"), ("💬", "WhatsApp Sipariş"), ("🏷", "Kampanya"), ("⭐", "Sadakat"),
                ("👤", "CRM"), ("📊", "Raporlar"), ("🧾", "Audit Log"), ("🔔", "Bildirimler") })
            {
                <div class="col-6 col-md-3">
                    <div class="landing-mini-card text-center h-100 py-3">
                        <div class="mb-1">@item.Item1</div>
                        <div class="fw-semibold small">@item.Item2</div>
                    </div>
                </div>
            }
        </div>

        <div class="landing-section-card mb-4">
            <h2 class="h5 mb-3">Demo sırasında şunları test edin</h2>
            <div class="row g-3">
                <div class="col-md-6"><div class="landing-mini-card">Sepet toplamı sunucu fiyatıyla hesaplanır</div></div>
                <div class="col-md-6"><div class="landing-mini-card">Kampanya auto-apply indirimi görünür</div></div>
                <div class="col-md-6"><div class="landing-mini-card">Confirmation ve tracking token çalışır</div></div>
                <div class="col-md-6"><div class="landing-mini-card">Panelde Kitchen / Reports / Notifications anlatılır</div></div>
            </div>
        </div>

        <div class="landing-note p-3">
            <strong>Güvenlik notu:</strong>
            <span class="text-muted small">
                Admin/Owner şifreleri public sayfada paylaşılmaz. Panel için /Account/Login kullanın.
                Public menü demosu herkese açıktır.
            </span>
        </div>
    </div>
</section>

<section class="py-5 landing-band">
    <div class="container text-center">
        <h2 class="h4 fw-bold mb-3">Kendi işletmeniz için ücretsiz başlayın</h2>
        <div class="d-flex flex-wrap justify-content-center gap-2">
            <a href="/Account/Register" class="btn btn-primary btn-lg">Ücretsiz Kayıt Ol</a>
            <a href="/Sales/RequestDemo" class="btn btn-outline-primary btn-lg">Demo Talep Et</a>
            <a href="/RoiCalculator" class="btn btn-outline-primary btn-lg">Demo sonrası değer hesapla</a>
            <a href="@Model.DemoMenuUrl" class="btn btn-outline-primary btn-lg" target="_blank" rel="noopener">Demo QR Menüyü Aç</a>
            <a href="/Pricing" class="btn btn-outline-secondary btn-lg">Planları İncele</a>
        </div>
    </div>
</section>
