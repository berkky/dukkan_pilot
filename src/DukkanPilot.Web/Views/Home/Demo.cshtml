@model DemoPageViewModel
@{
    ViewData["Title"] = "Demo";
    var cta = Model.AuthCta;
}

<section class="landing-page-hero py-5">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <span class="landing-pill landing-pill-dark mb-3">Demo Funnel</span>
                <h1 class="display-6 fw-bold mb-3">2 dakikada ürünü hissedin</h1>
                <p class="text-muted mb-0">
                    Public demo menü login istemez. Panel deneyimi için giriş yapın veya kendi işletmenizi oluşturun.
                    Demo hesap şifreleri bu sayfada paylaşılmaz.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-5">
                <div class="landing-demo-card h-100">
                    <div class="landing-pill landing-pill-dark mb-3">Public demo</div>
                    <h2 class="h4">@Model.DemoBusinessName</h2>
                    <p class="text-muted">QR menü + sepet + kampanya + sipariş takip akışı.</p>
                    <code class="landing-code d-block mb-3">@Model.DemoMenuUrl</code>
                    <div class="d-grid gap-2">
                        <a href="@Model.DemoMenuUrl" class="btn btn-success" target="_blank" rel="noopener">Demo Menüyü Aç</a>
                        <a href="@cta.PrimaryUrl" class="btn btn-primary">@(cta.IsAuthenticated ? cta.PrimaryText : "Kendi İşletmeni Oluştur")</a>
                        <a href="/Account/Login" class="btn btn-outline-secondary">Panel için Giriş Yap</a>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="landing-section-card h-100">
                    <h2 class="h5 mb-3">Test akışı</h2>
                    <ol class="landing-demo-steps mb-0">
                        <li>
                            <strong>Menüye gir</strong>
                            <span>@Model.DemoMenuUrl adresini açın.</span>
                        </li>
                        <li>
                            <strong>Sepete ürün ekle</strong>
                            <span>Ürün kartından sepete ekleyip özeti kontrol edin.</span>
                        </li>
                        <li>
                            <strong>Kampanya indirimi gör</strong>
                            <span>Uygun sepet tutarında sunucu tarafı indirim mesajını görün.</span>
                        </li>
                        <li>
                            <strong>Sipariş oluştur</strong>
                            <span>Confirmation ekranına gidin; WhatsApp mesajını inceleyin.</span>
                        </li>
                        <li>
                            <strong>Takip ekranını gör</strong>
                            <span>Sipariş durum sayfasında badge ve timeline’ı izleyin.</span>
                        </li>
                    </ol>
                </div>
            </div>
        </div>

        <div class="landing-note mt-4 p-3">
            <strong>Not:</strong>
            <span class="text-muted small">
                İşletme paneli (sipariş, mutfak, raporlar, Go-Live) için kimlik doğrulama gerekir.
                Public menü demosu herkese açıktır.
            </span>
        </div>
    </div>
</section>

<section class="py-5 landing-band">
    <div class="container text-center">
        <h2 class="h4 fw-bold mb-3">Beğendiniz mi?</h2>
        <div class="d-flex flex-wrap justify-content-center gap-2">
            <a href="/Account/Register" class="btn btn-primary">Ücretsiz Başla</a>
            <a href="/Features" class="btn btn-outline-primary">Özellikleri Gör</a>
            <a href="/Pricing" class="btn btn-outline-secondary">Planları İncele</a>
        </div>
    </div>
</section>
