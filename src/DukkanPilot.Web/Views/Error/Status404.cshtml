@model ErrorPageViewModel
@{
    ViewData["Title"] = "Sayfa Bulunamadı";
}

<section class="landing-page-hero py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="landing-section-card p-4 p-md-5 text-center">
                    <div class="display-6 fw-bold text-primary mb-2">404</div>
                    <h1 class="h3 fw-bold mb-3">Aradığın sayfa bulunamadı</h1>
                    <p class="text-muted mb-4">
                        Link hatalı olabilir veya sayfa taşınmış olabilir. Ana sayfadan devam edebilirsin.
                    </p>
                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        <a href="/" class="btn btn-primary">Ana Sayfa</a>
                        <a href="/Pricing" class="btn btn-outline-primary">Fiyatlar</a>
                        <a href="/Demo" class="btn btn-outline-secondary">Demo</a>
                        <a href="/m/demo-kafe" class="btn btn-outline-success" target="_blank" rel="noopener">Demo Menüyü Aç</a>
                    </div>
                    @if (Model.ShowRequestId)
                    {
                        <p class="small text-muted mt-4 mb-0">İstek kodu: <code>@Model.RequestId</code></p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
