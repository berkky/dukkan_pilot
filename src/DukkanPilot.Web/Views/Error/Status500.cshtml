@model ErrorPageViewModel
@{
    ViewData["Title"] = "Sunucu Hatası";
}

<section class="landing-page-hero py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="landing-section-card p-4 p-md-5 text-center">
                    <div class="display-6 fw-bold text-danger mb-2">500</div>
                    <h1 class="h3 fw-bold mb-3">Beklenmeyen bir sorun oluştu</h1>
                    <p class="text-muted mb-4">
                        İşlemi şu an tamamlayamadık. Lütfen biraz sonra tekrar dene.
                        Teknik detaylar güvenlik nedeniyle gösterilmez.
                    </p>
                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        <a href="/" class="btn btn-primary">Ana Sayfa</a>
                        <a href="/Account/Login" class="btn btn-outline-primary">Giriş Yap</a>
                        <a href="/Demo" class="btn btn-outline-secondary">Demo</a>
                    </div>
                    @if (Model.ShowRequestId)
                    {
                        <p class="small text-muted mt-4 mb-0">İstek kodu: <code>@Model.RequestId</code></p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
