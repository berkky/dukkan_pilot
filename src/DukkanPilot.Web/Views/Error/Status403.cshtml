@model ErrorPageViewModel
@{
    ViewData["Title"] = "Erişim Reddedildi";
}

<section class="landing-page-hero py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="landing-section-card p-4 p-md-5 text-center">
                    <div class="display-6 fw-bold text-warning mb-2">403</div>
                    <h1 class="h3 fw-bold mb-3">Bu işlem için yetkin yok</h1>
                    <p class="text-muted mb-4">
                        @if (Model.IsBusinessUser)
                        {
                            <text>Bu sayfa veya işlem Owner yetkisi gerektiriyor olabilir. Dashboard’a dönebilirsin.</text>
                        }
                        else if (!Model.IsAuthenticated)
                        {
                            <text>Devam etmek için giriş yapman gerekiyor.</text>
                        }
                        else
                        {
                            <text>Bu sayfaya erişim yetkin bulunmuyor.</text>
                        }
                    </p>
                    <div class="d-flex flex-wrap justify-content-center gap-2">
                        @if (Model.IsSuperAdmin)
                        {
                            <a href="/Admin/Dashboard" class="btn btn-primary">Admin Paneli</a>
                        }
                        else if (Model.IsBusinessUser)
                        {
                            <a href="/Business/Dashboard" class="btn btn-primary">İşletme Paneli</a>
                            <a href="/Business/GoLive" class="btn btn-outline-primary">Go-Live Merkezi</a>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-primary">Giriş Yap</a>
                        }
                        <a href="/" class="btn btn-outline-secondary">Ana Sayfa</a>
                    </div>
                    @if (Model.ShowRequestId)
                    {
                        <p class="small text-muted mt-4 mb-0">İstek kodu: <code>@Model.RequestId</code></p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
