<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DükkanPilot</title>
    <meta name="description" content="@(ViewData["MetaDescription"] as string ?? "DükkanPilot — QR menü, WhatsApp sipariş, sadakat ve kampanya SaaS.")" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="landing-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">DP</span> DükkanPilot
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Menüyü aç">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" href="/Features">Özellikler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Pricing">Fiyatlar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Demo">Demo</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login">Giriş Yap</a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn btn-primary btn-sm px-3" href="/Account/Register">Ücretsiz Başla</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="landing-footer">
        <div class="container py-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 small">
                <span>&copy; @DateTime.Now.Year DükkanPilot</span>
                <div class="d-flex flex-wrap gap-3">
                    <a href="/Features" class="link-light link-underline-opacity-0">Özellikler</a>
                    <a href="/Pricing" class="link-light link-underline-opacity-0">Fiyatlar</a>
                    <a href="/Demo" class="link-light link-underline-opacity-0">Demo</a>
                    <a href="/m/demo-kafe" class="link-light link-underline-opacity-0">Demo Menü</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
