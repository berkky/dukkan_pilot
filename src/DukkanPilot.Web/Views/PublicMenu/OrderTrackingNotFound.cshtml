@model PublicOrderTrackingNotFoundViewModel
@{
    ViewData["Title"] = "Sipariş Bulunamadı | DukkanPilot";
    Layout = "_PublicLayout";
}

<div class="public-menu-not-found">
    <div class="public-menu-not-found-card">
        <div class="public-menu-empty-icon">@(Model.IsExpired ? "⏱" : "🔍")</div>
        <h1 class="h5 mb-2">@(Model.IsExpired ? "Bağlantının Süresi Doldu" : "Sipariş Bulunamadı")</h1>
        <p class="text-muted mb-4">@Model.ErrorMessage</p>
        @if (!string.IsNullOrWhiteSpace(Model.BusinessSlug))
        {
            <a href="/m/@Model.BusinessSlug" class="btn btn-primary">Menüye Dön</a>
        }
        else
        {
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Ana Sayfaya Dön</a>
        }
    </div>
</div>
