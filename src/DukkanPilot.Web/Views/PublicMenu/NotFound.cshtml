@model string
@{
    ViewData["Title"] = "Menü Bulunamadı | DukkanPilot";
    Layout = "_PublicLayout";
}

<div class="public-menu-not-found">
    <div class="public-menu-not-found-card">
        <div class="public-menu-empty-icon">🔍</div>
        <h1 class="h5 mb-2">Menü Bulunamadı</h1>
        <p class="text-muted mb-4">
            <strong>@Model</strong> adresine ait aktif bir menü bulunamadı.
            Bağlantıyı kontrol edin veya işletmeyle iletişime geçin.
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Ana Sayfaya Dön</a>
    </div>
</div>
