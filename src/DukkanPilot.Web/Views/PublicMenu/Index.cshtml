@model PublicMenuViewModel

@Html.AntiForgeryToken()

<div class="public-menu-page"
     id="public-menu-root"
     style="--dp-theme-color: @Model.ThemeColor; --menu-theme: @Model.ThemeColor"
     data-business-id="@Model.BusinessId"
     data-order-url="/m/@Model.Slug/order"
     data-preview-url="/m/@Model.Slug/preview-order"
     data-whatsapp-number="@(Model.WhatsAppNumber ?? string.Empty)"
     data-currency="@Model.Currency">

    <header class="public-menu-header" style="background: linear-gradient(135deg, @Model.ThemeColor, color-mix(in srgb, @Model.ThemeColor 75%, #000))">
        <div class="d-flex align-items-start gap-3">
            @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
            {
                <img src="@Model.LogoUrl"
                     alt="@Model.BusinessName"
                     class="public-menu-logo"
                     onerror="this.hidden=true; this.nextElementSibling.hidden=false;" />
                <div class="public-menu-logo-placeholder" hidden aria-hidden="true">☕</div>
            }
            else
            {
                <div class="public-menu-logo-placeholder" aria-hidden="true">☕</div>
            }
            <div class="flex-grow-1 min-w-0">
                <h1 class="h4 mb-1 fw-bold">@Model.BusinessName</h1>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="public-menu-header-desc mb-0">@Model.Description</p>
                }
            </div>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.Address) || !string.IsNullOrWhiteSpace(Model.Phone))
    {
        <div class="public-menu-info">
            @if (!string.IsNullOrWhiteSpace(Model.Address))
            {
                <div class="public-menu-info-item">
                    <span class="public-menu-info-icon" aria-hidden="true">📍</span>
                    <span>@Model.Address</span>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Phone))
            {
                <div class="public-menu-info-item">
                    <span class="public-menu-info-icon" aria-hidden="true">📞</span>
                    <a class="public-menu-info-link" href="tel:@Model.Phone">@Model.Phone</a>
                </div>
            }
        </div>
    }

    @if (Model.Campaigns.Any())
    {
        <section class="public-promotions-section" aria-label="Aktif kampanyalar">
            <div class="public-promotions-header">
                <h2 class="public-promotions-title">Aktif Fırsatlar</h2>
            </div>
            <div class="public-campaign-scroll">
                @foreach (var campaign in Model.Campaigns)
                {
                    <article class="public-campaign-card">
                        @if (!string.IsNullOrWhiteSpace(campaign.ImageUrl))
                        {
                            <img src="@campaign.ImageUrl" alt="" class="public-campaign-image" loading="lazy" />
                        }
                        <div class="public-campaign-body">
                            <div class="public-campaign-title">@campaign.Title</div>
                            @if (!string.IsNullOrWhiteSpace(campaign.Description))
                            {
                                <p class="public-campaign-desc">@campaign.Description</p>
                            }
                            @if (campaign.DiscountValue > 0)
                            {
                                <div class="public-campaign-discount-badge">@campaign.CampaignBadgeText</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(campaign.MinimumOrderText))
                            {
                                <div class="public-campaign-meta">@campaign.MinimumOrderText</div>
                            }
                            @if (campaign.EndDate.HasValue)
                            {
                                <div class="public-campaign-meta">
                                    @campaign.EndDate.Value.ToLocalTime().ToString("dd.MM.yyyy") tarihine kadar
                                </div>
                            }
                            @if (campaign.IsAutoApply)
                            {
                                <span class="badge public-campaign-badge public-campaign-badge-auto">Sepette otomatik uygulanır</span>
                            }
                            else
                            {
                                <span class="badge public-campaign-badge">İşletme onayında değerlendirilebilir</span>
                            }
                        </div>
                    </article>
                }
            </div>
        </section>
    }

    @if (Model.Rewards.Any())
    {
        <section class="public-rewards-section" aria-label="Ödül vitrini">
            <div class="public-promotions-header">
                <h2 class="public-promotions-title">Sadakat Ödülleri</h2>
                <p class="public-promotions-subtitle mb-0">Puan harcama otomatik yapılmaz. Talebinizi sipariş notuna ekleyebilirsiniz.</p>
            </div>
            <div class="public-reward-grid">
                @foreach (var reward in Model.Rewards)
                {
                    <article class="public-reward-card" data-reward-id="@reward.Id" data-reward-name="@reward.Name">
                        <div class="public-reward-name">@reward.Name</div>
                        @if (!string.IsNullOrWhiteSpace(reward.Description))
                        {
                            <p class="public-reward-desc">@reward.Description</p>
                        }
                        <div class="public-reward-points">@reward.RequiredPoints puan</div>
                        <button type="button"
                                class="btn btn-sm btn-outline-primary public-reward-select-btn"
                                data-reward-name="@reward.Name">
                            Siparişe Ekle
                        </button>
                    </article>
                }
            </div>
            <div id="selected-reward-banner" class="public-selected-reward" hidden>
                <span>Seçili ödül talebi: <strong id="selected-reward-name"></strong></span>
                <button type="button" class="btn btn-sm btn-link text-danger" id="clear-reward-btn">Kaldır</button>
            </div>
        </section>
    }

    @if (!Model.Categories.Any())
    {
        <div class="public-menu-empty">
            <div class="public-menu-empty-icon">📋</div>
            <p class="mb-0">Henüz menüde kategori bulunmuyor.</p>
        </div>
    }
    else
    {
        <nav class="category-nav-wrapper">
            <div class="category-nav">
                @foreach (var category in Model.Categories)
                {
                    <a class="category-nav-link" href="#category-@category.Id">@category.Name</a>
                }
            </div>
        </nav>

        @foreach (var category in Model.Categories)
        {
            <section id="category-@category.Id" class="menu-category-section">
                <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
                    <h2 class="menu-category-title mb-0">@category.Name</h2>
                    @if (Model.HasActiveCampaigns)
                    {
                        <span class="badge bg-warning text-dark">Fırsat Dönemi</span>
                    }
                </div>

                @if (!category.Products.Any())
                {
                    <p class="text-muted small">Bu kategoride ürün bulunmuyor.</p>
                }
                else
                {
                    @foreach (var product in category.Products)
                    {
                        <article class="product-card">
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" class="product-card-image" loading="lazy" />
                            }
                            else
                            {
                                <div class="product-card-image-placeholder" aria-hidden="true">🍽️</div>
                            }
                            <div class="product-card-body">
                                <div class="d-flex align-items-start gap-2">
                                    <div class="product-card-name flex-grow-1">@product.Name</div>
                                    @if (Model.HasActiveCampaigns)
                                    {
                                        <span class="badge public-product-offer-badge">Fırsat</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(product.Description))
                                {
                                    <p class="product-card-desc">@product.Description</p>
                                }
                                <div class="d-flex align-items-center justify-content-between gap-2 mt-1">
                                    <div class="product-card-price mb-0">
                                        @Model.FormatPrice(product.Price)
                                    </div>
                                    <button type="button"
                                            class="btn btn-sm btn-add-to-cart"
                                            style="background: var(--menu-theme); border-color: var(--menu-theme); color: #fff;"
                                            data-product-id="@product.Id"
                                            data-product-name="@product.Name"
                                            data-product-price="@product.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)">
                                        Sepete Ekle
                                    </button>
                                </div>
                            </div>
                        </article>
                    }
                }
            </section>
        }
    }

    <footer class="public-menu-footer">
        DükkanPilot ile oluşturuldu
    </footer>
</div>

<div id="cart-bar" class="cart-bar" style="--dp-theme-color: @Model.ThemeColor; --menu-theme: @Model.ThemeColor" hidden>
    <button type="button"
            class="cart-bar-button"
            data-bs-toggle="offcanvas"
            data-bs-target="#cartOffcanvas"
            aria-controls="cartOffcanvas">
        <span class="cart-bar-label">Sepetim</span>
        <span class="cart-bar-meta">
            <span id="cart-item-count">0</span> ürün · <span id="cart-total">@Model.FormatPrice(0)</span>
        </span>
    </button>
</div>

<div class="offcanvas offcanvas-bottom cart-offcanvas" style="--dp-theme-color: @Model.ThemeColor; --menu-theme: @Model.ThemeColor" tabindex="-1" id="cartOffcanvas" aria-labelledby="cartOffcanvasLabel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title fw-bold" id="cartOffcanvasLabel">Sipariş Özeti</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Kapat"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column">
        <div id="cart-empty" class="cart-empty text-muted text-center py-3" hidden>
            Sepetiniz boş.
        </div>

        <div id="cart-items" class="cart-items flex-grow-1"></div>

        <div id="cart-pricing-summary" class="cart-pricing-summary" hidden>
            <div class="cart-pricing-row">
                <span>Ara Toplam</span>
                <span id="cart-subtotal">@Model.FormatPrice(0)</span>
            </div>
            <div class="cart-pricing-row cart-pricing-discount" id="cart-discount-row" hidden>
                <span>İndirim</span>
                <span id="cart-discount">@Model.FormatPrice(0)</span>
            </div>
            <div id="cart-campaign-message" class="cart-campaign-message small text-muted" hidden></div>
            <div id="cart-applied-campaign" class="cart-applied-campaign small fw-semibold" hidden></div>
            <div id="cart-loyalty-preview" class="cart-loyalty-preview" hidden>
                <span class="cart-loyalty-icon" aria-hidden="true">★</span>
                <span id="cart-loyalty-text"></span>
            </div>
        </div>

        <div class="cart-customer-fields mt-3">
            <div class="mb-2">
                <label for="customer-name" class="form-label small mb-1">Ad Soyad (opsiyonel)</label>
                <input type="text" class="form-control form-control-sm" id="customer-name" maxlength="200" placeholder="Adınız" />
            </div>
            <div class="mb-2">
                <label for="customer-phone" class="form-label small mb-1">Telefon (opsiyonel)</label>
                <input type="tel" class="form-control form-control-sm" id="customer-phone" maxlength="20" placeholder="05xx xxx xx xx" />
            </div>
            <div class="mb-2">
                <label for="order-notes" class="form-label small mb-1">Sipariş notu (opsiyonel)</label>
                <textarea class="form-control form-control-sm" id="order-notes" rows="2" maxlength="1000" placeholder="Örn. şekersiz olsun"></textarea>
            </div>
        </div>

        <div id="whatsapp-warning" class="alert alert-warning py-2 small mb-2" hidden>
            Bu işletme için WhatsApp numarası tanımlı değil. Sipariş verilemiyor.
        </div>

        <div id="cart-order-error" class="alert alert-danger py-2 small mb-2" hidden role="alert"></div>

        <div class="cart-footer border-top pt-3 mt-auto">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="fw-semibold">Toplam</span>
                <span class="fw-bold fs-5" id="cart-summary-total" style="color: var(--menu-theme);">@Model.FormatPrice(0)</span>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary flex-shrink-0" id="cart-clear-btn">Temizle</button>
                <button type="button" class="btn flex-grow-1 text-white" id="cart-place-order-btn" style="background: var(--menu-theme); border-color: var(--menu-theme);">
                    WhatsApp ile Sipariş Ver
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/public-menu-cart.js" asp-append-version="true"></script>
}
