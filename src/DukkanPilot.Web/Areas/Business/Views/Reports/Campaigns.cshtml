@model CampaignReportIndexViewModel
@using System.Globalization
@using DukkanPilot.Web.Areas.Business.Models
@{
    ViewData["Title"] = "Kampanya Raporu";
    ViewData["Subtitle"] = "Kampanya performans analizi";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
    var impact = Model.Impact;
    var exportUrl = $"/Business/Reports/CampaignsExportCsv?period={Uri.EscapeDataString(Model.Period)}&startDate={Model.StartDateLocal:yyyy-MM-dd}&endDate={Model.EndDateLocal:yyyy-MM-dd}";
}

<div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
    <div>
        <h2 class="h4 mb-1">Kampanya Performansı</h2>
        <p class="text-muted mb-0">İndirim etkisi, kampanya kullanımı ve net ciro.</p>
    </div>
    <a href="@exportUrl" class="btn btn-outline-success btn-sm">CSV İndir</a>
</div>

<partial name="_ReportNav" />

@if (Model.WasDateRangeAdjusted)
{
    <div class="alert alert-info py-2 small mb-3" role="alert">
        Başlangıç tarihi bitiş tarihinden büyüktü; tarihler otomatik düzeltildi.
    </div>
}

<div class="panel-card mb-4">
    <div class="panel-card-header">
        <h3 class="h6 mb-0">Dönem Filtresi — @Model.PeriodLabel</h3>
    </div>
    <div class="panel-card-body">
        <div class="d-flex flex-wrap gap-2 mb-3">
            <a href="/Business/Reports/Campaigns?period=today" class="btn btn-sm @(Model.Period == "today" ? "btn-primary" : "btn-outline-primary")">Bugün</a>
            <a href="/Business/Reports/Campaigns?period=last7" class="btn btn-sm @(Model.Period == "last7" ? "btn-primary" : "btn-outline-primary")">Son 7 Gün</a>
            <a href="/Business/Reports/Campaigns?period=thismonth" class="btn btn-sm @(Model.Period == "thismonth" ? "btn-primary" : "btn-outline-primary")">Bu Ay</a>
        </div>
        <form method="get" action="/Business/Reports/Campaigns" class="row g-2 align-items-end">
            <input type="hidden" name="period" value="custom" />
            <div class="col-sm-4 col-md-3">
                <label for="startDate" class="form-label small mb-1">Başlangıç Tarihi</label>
                <input type="date" class="form-control form-control-sm" id="startDate" name="startDate" value="@Model.StartDateLocal.ToString("yyyy-MM-dd")" required />
            </div>
            <div class="col-sm-4 col-md-3">
                <label for="endDate" class="form-label small mb-1">Bitiş Tarihi</label>
                <input type="date" class="form-control form-control-sm" id="endDate" name="endDate" value="@Model.EndDateLocal.ToString("yyyy-MM-dd")" required />
            </div>
            <div class="col-sm-4 col-md-3">
                <button type="submit" class="btn btn-primary btn-sm w-100">Uygula</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-4">
        <div class="stat-card h-100">
            <div class="stat-label">Kampanyalı Sipariş</div>
            <div class="stat-value">@impact.OrdersWithCampaign</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="stat-card h-100">
            <div class="stat-label">Kampanyasız Sipariş</div>
            <div class="stat-value">@impact.OrdersWithoutCampaign</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="stat-card h-100">
            <div class="stat-label">Toplam İndirim</div>
            <div class="stat-value fs-5">@impact.TotalDiscount.ToString("N2", culture) ₺</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="stat-card h-100">
            <div class="stat-label">Kampanyalı Ciro</div>
            <div class="stat-value fs-5">@impact.CampaignOrderRevenue.ToString("N2", culture) ₺</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="stat-card h-100">
            <div class="stat-label">Ort. Kampanyalı Sepet</div>
            <div class="stat-value fs-5">@impact.AverageCampaignBasket.ToString("N2", culture) ₺</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="stat-card h-100">
            <div class="stat-label">İndirim Oranı</div>
            <div class="stat-value">%@impact.DiscountRatePercent.ToString("N2", culture)</div>
        </div>
    </div>
</div>

@if (impact.OrdersWithCampaign == 0)
{
    @await Html.PartialAsync("~/Views/Shared/_EmptyState.cshtml", new EmptyStateViewModel
    {
        Icon = "🏷️",
        Title = "Kampanyalı sipariş yok",
        Description = "Seçili dönemde kampanya uygulanmış sipariş bulunamadı. Kampanya oluşturup yayına alın veya dönemi genişletin.",
        PrimaryActionText = "Kampanya Oluştur",
        PrimaryActionUrl = "/Business/Campaigns/Create",
        SecondaryActionText = "Kampanyalar",
        SecondaryActionUrl = "/Business/Campaigns",
        HelpText = "Otomatik kampanyalar uygun sepetlerde siparişe uygulanır."
    })
}

<div class="panel-card mb-4">
    <div class="panel-card-header">
        <h3 class="h6 mb-0">Kampanya Bazlı Performans</h3>
    </div>
    <div class="panel-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Kampanya</th>
                        <th class="text-end">Sipariş</th>
                        <th class="text-end">Ara Toplam</th>
                        <th class="text-end">İndirim</th>
                        <th class="text-end">Net Ciro</th>
                        <th class="text-end">Ort. Sepet</th>
                        <th class="text-end">Ort. İndirim</th>
                        <th class="text-end">Son Kullanım</th>
                    </tr>
                </thead>
                <tbody>
                @if (impact.TopCampaigns.Count == 0)
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">Seçili dönemde kampanyalı sipariş yok.</td>
                    </tr>
                }
                else
                {
                    foreach (var row in impact.TopCampaigns)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @if (row.CampaignId.HasValue)
                                {
                                    <a href="/Business/Campaigns/Details/@row.CampaignId">@row.CampaignName</a>
                                }
                                else
                                {
                                    @row.CampaignName
                                }
                            </td>
                            <td class="text-end">@row.OrderCount</td>
                            <td class="text-end">@row.TotalSubtotal.ToString("N2", culture) ₺</td>
                            <td class="text-end text-success">@row.TotalDiscount.ToString("N2", culture) ₺</td>
                            <td class="text-end">@row.NetRevenue.ToString("N2", culture) ₺</td>
                            <td class="text-end">@row.AverageBasket.ToString("N2", culture) ₺</td>
                            <td class="text-end">@row.AverageDiscount.ToString("N2", culture) ₺</td>
                            <td class="text-end">@(row.LastUsedAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm", culture) ?? "-")</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="panel-card">
    <div class="panel-card-header">
        <h3 class="h6 mb-0">Son Kampanyalı Siparişler</h3>
    </div>
    <div class="panel-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Sipariş No</th>
                        <th>Müşteri</th>
                        <th>Durum</th>
                        <th class="text-end">Toplam</th>
                        <th>Tarih</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.RecentCampaignOrders.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Kampanyalı sipariş yok.</td>
                    </tr>
                }
                else
                {
                    foreach (var order in Model.RecentCampaignOrders)
                    {
                        <tr>
                            <td class="fw-semibold">@order.OrderNumber</td>
                            <td>@(order.CustomerName ?? "-")</td>
                            <td>
                                <span class="badge @OrderDisplayHelper.GetStatusBadgeClass(order.Status)">
                                    @OrderDisplayHelper.GetStatusLabel(order.Status)
                                </span>
                            </td>
                            <td class="text-end">@order.TotalAmount.ToString("N2", culture) ₺</td>
                            <td>@order.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm", culture)</td>
                            <td class="text-end">
                                <a href="/Business/Orders/Details/@order.OrderId" class="btn btn-sm btn-outline-primary">Detay</a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
