@model CustomerDetailsViewModel

@{

    ViewData["Title"] = "Müşteri Sil";

    ViewData["Subtitle"] = Model.Name;

}



<div class="panel-card border-danger">

    <div class="panel-card-header bg-danger-subtle">

        <h3 class="h6 mb-0 text-danger">Müşteriyi Pasif Yap</h3>

    </div>

    <div class="panel-card-body">

        <div class="alert alert-warning">

            <strong>@Model.Name</strong> müşterisini pasif duruma almak istediğinize emin misiniz?

            Bu işlem veritabanından silme yapmaz; müşteri <code>IsActive = false</code> olarak işaretlenir.

        </div>

        <dl class="row mb-4">

            <dt class="col-sm-3">Telefon</dt>

            <dd class="col-sm-9">@(Model.Phone ?? "-")</dd>

            <dt class="col-sm-3">Toplam Puan</dt>

            <dd class="col-sm-9">@Model.TotalPoints</dd>

            <dt class="col-sm-3">Sipariş Sayısı</dt>

            <dd class="col-sm-9">@Model.OrderHistory.Count</dd>

            <dt class="col-sm-3">Durum</dt>

            <dd class="col-sm-9">

                @if (Model.IsActive)

                {

                    <span class="badge bg-success">Aktif</span>

                }

                else

                {

                    <span class="badge bg-secondary">Zaten Pasif</span>

                }

            </dd>

        </dl>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">

            @Html.AntiForgeryToken()

            <button type="submit" class="btn btn-danger" @(Model.IsActive ? "" : "disabled")>Pasif Yap</button>

            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>

        </form>

    </div>

</div>

