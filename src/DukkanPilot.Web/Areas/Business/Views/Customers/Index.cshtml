@model IEnumerable<CustomerListViewModel>

@using System.Globalization

@{

    ViewData["Title"] = "Müşteriler";

    ViewData["Subtitle"] = "Müşteri listesi";

    var culture = CultureInfo.GetCultureInfo("tr-TR");

}



<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="h4 mb-1">Müşteriler</h2>

        <p class="text-muted mb-0">Demo Kafe müşteri kayıtları</p>

    </div>

    <a asp-action="Create" class="btn btn-primary">+ Yeni Müşteri</a>

</div>



<div class="panel-card">

    <div class="panel-card-body p-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                    <tr>

                        <th>Id</th>

                        <th>Müşteri Adı</th>

                        <th>Telefon</th>

                        <th>Toplam Puan</th>

                        <th>Durum</th>

                        <th>Sipariş Sayısı</th>

                        <th>Son Sipariş</th>

                        <th class="text-end">İşlemler</th>

                    </tr>

                </thead>

                <tbody>

                @if (!Model.Any())

                {

                    <tr>

                        <td colspan="8" class="text-center text-muted py-4">Henüz müşteri yok.</td>

                    </tr>

                }

                else

                {

                    foreach (var item in Model)

                    {

                        <tr>

                            <td>@item.Id</td>

                            <td class="fw-semibold">@item.Name</td>

                            <td>@(item.Phone ?? "-")</td>

                            <td>@item.TotalPoints</td>

                            <td>

                                @if (item.IsActive)

                                {

                                    <span class="badge bg-success">Aktif</span>

                                }

                                else

                                {

                                    <span class="badge bg-secondary">Pasif</span>

                                }

                            </td>

                            <td>@item.OrderCount</td>

                            <td>

                                @(item.LastOrderDate.HasValue

                                    ? item.LastOrderDate.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm", culture)

                                    : "-")

                            </td>

                            <td class="text-end">

                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detay</a>

                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Sil</a>

                            </td>

                        </tr>

                    }

                }

                </tbody>

            </table>

        </div>

    </div>

</div>

