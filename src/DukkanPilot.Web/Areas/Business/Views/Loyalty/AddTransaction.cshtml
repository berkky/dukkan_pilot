@model LoyaltyTransactionFormViewModel
@using DukkanPilot.Core.Enums
@{
    ViewData["Title"] = "Manuel Puan İşlemi";
    ViewData["Subtitle"] = "Puan ekle veya düş";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-1">Manuel Puan İşlemi</h2>
        <p class="text-muted mb-0">Müşteriye puan ekleme veya düşme</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Geri Dön</a>
</div>

<div class="panel-card">
    <div class="panel-card-body">
        @if (!Model.AvailableCustomers.Any())
        {
            <div class="alert alert-warning mb-0">
                Aktif müşteri bulunamadı. Önce <a href="/Business/Customers/Create">müşteri ekleyin</a>.
            </div>
        }
        else
        {
            <form asp-action="AddTransaction" method="post">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label asp-for="CustomerId" class="form-label"></label>
                        <select asp-for="CustomerId" asp-items="Model.AvailableCustomers" class="form-select">
                            <option value="">Müşteri seçin</option>
                        </select>
                        <span asp-validation-for="CustomerId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Points" class="form-label"></label>
                        <input asp-for="Points" class="form-control" min="1" />
                        <span asp-validation-for="Points" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Type" class="form-label"></label>
                        <select asp-for="Type" class="form-select">
                            <option value="@((int)LoyaltyTransactionType.Earn)">Kazanım (Earn)</option>
                            <option value="@((int)LoyaltyTransactionType.Redeem)">Kullanım (Redeem)</option>
                        </select>
                        <span asp-validation-for="Type" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Kaydet</button>
                    <a asp-action="Transactions" class="btn btn-outline-secondary">İptal</a>
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
