@model IEnumerable<LoyaltyTransactionListViewModel>
@using System.Globalization
@{
    ViewData["Title"] = "Puan Hareketleri";
    ViewData["Subtitle"] = "Sadakat işlem geçmişi";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2 class="h4 mb-1">Puan Hareketleri</h2>
        <p class="text-muted mb-0">Tüm sadakat işlemleri</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="AddTransaction" class="btn btn-primary">Manuel Puan İşlemi</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Geri Dön</a>
    </div>
</div>

<div class="panel-card">
    <div class="panel-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tarih</th>
                        <th>Müşteri Adı</th>
                        <th>Telefon</th>
                        <th>İşlem Tipi</th>
                        <th>Puan</th>
                        <th>Açıklama</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Henüz puan hareketi yok.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm", culture)</td>
                            <td class="fw-semibold">@item.CustomerName</td>
                            <td>@(item.CustomerPhone ?? "-")</td>
                            <td>
                                <span class="badge @LoyaltyDisplayHelper.GetTypeBadgeClass(item.Type)">
                                    @LoyaltyDisplayHelper.GetTypeLabel(item.Type)
                                </span>
                            </td>
                            <td>@item.Points</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
