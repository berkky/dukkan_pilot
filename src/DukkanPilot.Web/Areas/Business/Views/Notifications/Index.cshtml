@model DukkanPilot.Web.Areas.Business.Models.NotificationIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Bildirim Merkezi";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
    string SeverityClass(string s) => s switch
    {
        "Critical" => "bg-danger",
        "Warning" => "bg-warning text-dark",
        "Success" => "bg-success",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2 class="h4 mb-1">Bildirim Merkezi</h2>
        <p class="text-muted mb-0">İşletmeniz için dikkat gerektiren uyarılar ve olaylar</p>
    </div>
    <form method="post" action="/Business/Notifications/MarkAllRead">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-secondary btn-sm" @(Model.UnreadCount == 0 ? "disabled" : null)>
            Tümünü okundu yap
        </button>
    </form>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Okunmamış</div>
            <div class="stat-value">@Model.UnreadCount</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Bugün</div>
            <div class="stat-value">@Model.TodayCount</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Kritik</div>
            <div class="stat-value">@Model.CriticalCount</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Uyarı</div>
            <div class="stat-value">@Model.WarningCount</div>
        </div>
    </div>
</div>

<div class="panel-card mb-4">
    <div class="panel-card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Ara</label>
                <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="Başlık, mesaj, tip" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Tip</label>
                <input type="text" name="type" value="@Model.Type" class="form-control form-control-sm" placeholder="NewOrder" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Severity</label>
                <select name="severity" class="form-select form-select-sm">
                    <option value="">Tümü</option>
                    @foreach (var s in new[] { "Info", "Success", "Warning", "Critical" })
                    {
                        if (Model.Severity == s) { <option value="@s" selected>@s</option> }
                        else { <option value="@s">@s</option> }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" name="unreadOnly" value="true" id="unreadOnly" @(Model.UnreadOnly ? "checked" : null) />
                    <label class="form-check-label small" for="unreadOnly">Sadece okunmamış</label>
                </div>
            </div>
            <div class="col-md-1">
                <label class="form-label small">Başlangıç</label>
                <input type="date" name="startDate" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
            </div>
            <div class="col-md-1">
                <label class="form-label small">Bitiş</label>
                <input type="date" name="endDate" value="@(Model.EndDate?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary btn-sm w-100">Filtrele</button>
            </div>
        </form>
    </div>
</div>

@if (Model.Items.Count == 0)
{
    <div class="panel-card">
        <div class="panel-card-body text-center py-5">
            <p class="text-muted mb-0">Şu an yeni bildiriminiz yok.</p>
        </div>
    </div>
}
else
{
    <div class="panel-card">
        <div class="list-group list-group-flush">
            @foreach (var item in Model.Items)
            {
                <div class="list-group-item @(item.IsRead ? "" : "bg-light")">
                    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                                <span class="badge @SeverityClass(item.Severity)">@item.Severity</span>
                                <span class="badge bg-light text-dark border">@item.Type</span>
                                @if (!item.IsRead)
                                {
                                    <span class="badge bg-primary">Yeni</span>
                                }
                            </div>
                            <div class="fw-semibold">@item.Title</div>
                            <div class="text-muted small">@item.Message</div>
                            <div class="text-muted small mt-1">@item.CreatedAtUtc.ToLocalTime().ToString("g", culture)</div>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            @if (!string.IsNullOrWhiteSpace(item.ActionUrl))
                            {
                                <a href="@item.ActionUrl" class="btn btn-sm btn-outline-primary">Git</a>
                            }
                            @if (!item.IsRead)
                            {
                                <form method="post" action="/Business/Notifications/MarkRead/@item.Id">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Okundu</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3" aria-label="Bildirim sayfalama">
            <ul class="pagination pagination-sm">
                @for (var p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link"
                           href="?page=@p&search=@Model.Search&type=@Model.Type&severity=@Model.Severity&unreadOnly=@Model.UnreadOnly&startDate=@(Model.StartDate?.ToString("yyyy-MM-dd"))&endDate=@(Model.EndDate?.ToString("yyyy-MM-dd"))">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
