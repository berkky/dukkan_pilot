@model CategoriesIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Kategoriler";
    ViewData["Subtitle"] = "Menü kategorileri";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
}

<div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
    <div>
        <h2 class="h4 mb-1">Kategoriler</h2>
        <p class="text-muted mb-0">Menü kategorilerinizi yönetin ve ürün dağılımını görün.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a href="/Business/MenuStudio" class="btn btn-outline-secondary btn-sm">Menü Stüdyosu</a>
        <a asp-action="Create" class="btn btn-primary btn-sm">+ Yeni Kategori</a>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/_HelpCard.cshtml", new HelpCardViewModel
{
    Title = "Bu ekran ne işe yarar?",
    Description = "Kategoriler public menüde ürünleri gruplar. Pasif kategoriler ve ürünleri müşteriye görünmez.",
    ActionText = "Menü Stüdyosu",
    ActionUrl = "/Business/MenuStudio",
    HelpGuideText = "Kategori rehberi",
    HelpGuideUrl = "/Business/HelpCenter/Article/kategori-urun-ekleme"
})

@if (Model.TotalCategories > 0 && Model.ActiveCategories == 0)
{
    @await Html.PartialAsync("~/Views/Shared/_HelpCard.cshtml", new HelpCardViewModel
    {
        Title = "Public menünüzde görünür kategori yok",
        Description = "En az bir kategoriyi aktif yaparak menüyü yayına hazır hale getirin.",
        ActionText = "Kategorileri Yönet",
        ActionUrl = "/Business/Categories",
        Variant = "warning"
    })
}

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="stat-card h-100">
            <div class="stat-label">Toplam Kategori</div>
            <div class="stat-value">@Model.TotalCategories</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card h-100">
            <div class="stat-label">Aktif Kategori</div>
            <div class="stat-value text-success">@Model.ActiveCategories</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="stat-card h-100">
            <div class="stat-label">Pasif Kategori</div>
            <div class="stat-value text-secondary">@Model.PassiveCategories</div>
        </div>
    </div>
</div>

@if (Model.TotalCategories == 0)
{
    @await Html.PartialAsync("~/Views/Shared/_EmptyState.cshtml", new EmptyStateViewModel
    {
        Icon = "📋",
        Title = "Menünüzü başlatın",
        Description = "Menünüzü başlatmak için ilk kategorinizi oluşturun.",
        PrimaryActionText = "Kategori Oluştur",
        PrimaryActionUrl = "/Business/Categories/Create",
        SecondaryActionText = "Menü Stüdyosu",
        SecondaryActionUrl = "/Business/MenuStudio",
        HelpText = "Örn: Kahveler, Tatlılar, Ana Yemekler"
    })
}
else
{
<div class="panel-card">
    <div class="panel-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Kategori Adı</th>
                        <th>Sıra</th>
                        <th>Ürün</th>
                        <th>Aktif Ürün</th>
                        <th>Ort. Fiyat</th>
                        <th>Public Menü</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Categories.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">Henüz kategori yok.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model.Categories)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.SortOrder</td>
                            <td>@item.ProductCount</td>
                            <td>@item.ActiveProductCount</td>
                            <td>@item.AveragePrice.ToString("N2", culture) ₺</td>
                            <td>
                                @if (item.IsPublicVisible)
                                {
                                    <span class="badge bg-success">Görünür</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Gizli</span>
                                }
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex flex-wrap justify-content-end gap-1">
                                    <a href="/Business/Products?categoryId=@item.Id" class="btn btn-sm btn-outline-primary">Ürünleri Gör</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detay</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                                    <form method="post" action="/Business/Categories/ToggleActive/@item.Id" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                            @(item.IsActive ? "Pasif Yap" : "Aktif Yap")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
}
