@model BusinessSettingsViewModel
@{
    ViewData["Title"] = "İşletme Ayarları";
    ViewData["Subtitle"] = Model.BusinessName;
    var publicMenuUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Model.PublicMenuPath}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-1">İşletme Ayarları</h2>
        <p class="text-muted mb-0">İşletme bilgileri ve public menü ayarları</p>
    </div>
    <a href="/Business/Dashboard" class="btn btn-outline-secondary">Dashboard</a>
</div>

<div class="panel-card mb-4">
    <div class="panel-card-header">
        <h3 class="h6 mb-0">Public Menü</h3>
    </div>
    <div class="panel-card-body">
        <p class="mb-2">Müşterileriniz menünüze aşağıdaki adresten erişir:</p>
        <div class="d-flex flex-wrap align-items-center gap-2">
            <code>@Model.PublicMenuPath</code>
            <a href="@Model.PublicMenuPath" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">Menüyü Aç</a>
        </div>
        <p class="text-muted small mt-2 mb-0">Tam URL: <span class="text-break">@publicMenuUrl</span></p>
    </div>
</div>

<div class="panel-card">
    <div class="panel-card-body">
        <form asp-action="Index" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="BusinessName" class="form-label"></label>
                    <input asp-for="BusinessName" class="form-control" />
                    <span asp-validation-for="BusinessName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Slug" class="form-label"></label>
                    <input asp-for="Slug" class="form-control" readonly />
                    <div class="form-text">Slug bu aşamada değiştirilemez.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="WhatsAppNumber" class="form-label"></label>
                    <input asp-for="WhatsAppNumber" class="form-control" placeholder="905551234567" />
                    <span asp-validation-for="WhatsAppNumber" class="text-danger small"></span>
                    <div class="form-text">WhatsApp sipariş yönlendirmesi için kullanılır.</div>
                </div>
                <div class="col-md-6">
                    <label asp-for="Currency" class="form-label"></label>
                    <input asp-for="Currency" class="form-control" />
                    <span asp-validation-for="Currency" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="ThemeColor" class="form-label"></label>
                    <div class="d-flex align-items-center gap-2">
                        <input asp-for="ThemeColor" class="form-control" />
                        <span class="d-inline-block rounded border flex-shrink-0" style="width:2.25rem;height:2.25rem;background-color:@Model.ThemeColor"></span>
                    </div>
                    <span asp-validation-for="ThemeColor" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="LogoUrl" class="form-label"></label>
                    <input asp-for="LogoUrl" class="form-control" />
                    <span asp-validation-for="LogoUrl" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label"></label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label class="form-label">Durum</label>
                    <div>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </div>
                    <div class="form-text">İşletme durumu yalnızca admin tarafından değiştirilebilir.</div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a href="/Business/Dashboard" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
