@model BusinessDashboardViewModel
@using System.Globalization
@using DukkanPilot.Core.Enums
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Subtitle"] = Model.BusinessName;
    var culture = CultureInfo.GetCultureInfo("tr-TR");
    var statusTotal = Model.StatusDistribution.TotalCount;
    int StatusPercent(int count) => statusTotal > 0 ? (int)Math.Round(count * 100.0 / statusTotal) : 0;
}

@if (!Model.Subscription.HasValidSubscription)
{
    <div class="alert alert-warning d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <strong>Aboneliğiniz aktif değil.</strong> Yönetim modülleri kısıtlandı.
        </div>
        @if (Model.IsBusinessOwner)
        {
            <a href="/Business/Billing" class="btn btn-sm btn-warning">Abonelik durumunu görüntüle</a>
        }
        else
        {
            <span class="small text-muted">İşletme sahibinizle iletişime geçin.</span>
        }
    </div>
}

<div class="page-header mb-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h2 class="h4 mb-1">Hoş Geldiniz — @Model.BusinessName</h2>
        <p class="text-muted mb-0">İşletme performans özeti</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a href="/Business/Onboarding" class="btn btn-primary">Kurulum Sihirbazı</a>
        <a href="/Business/GoLive" class="btn btn-success">Go-Live Merkezi</a>
        <a href="/Business/Orders/Kitchen" class="btn btn-outline-secondary">Mutfak Modu</a>
        <a href="/Business/QrMenu" class="btn btn-outline-primary">QR Menü</a>
        <a href="/Business/Reports" class="btn btn-outline-primary">Raporlar</a>
    </div>
</div>

@if (Model.OnboardingStatus is not null)
{
    <div class="panel-card mb-4 onboarding-dashboard-card @Model.OnboardingStatus.CardVariantClass">
        <div class="panel-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="h6 mb-0">Kurulum Sihirbazı</h3>
            <span class="badge @Model.OnboardingStatus.StatusBadgeClass">@Model.OnboardingStatus.StatusLabel</span>
        </div>
        <div class="panel-card-body">
            <div class="row g-3 align-items-center">
                <div class="col-sm-3 col-md-2">
                    <div class="onboarding-score-ring onboarding-score-ring-sm" aria-label="Onboarding skoru @Model.OnboardingStatus.Score">
                        <span class="onboarding-score-value">@Model.OnboardingStatus.Score</span>
                    </div>
                </div>
                <div class="col-sm-9 col-md-7">
                    @if (Model.OnboardingStatus.IsReadyOrLive)
                    {
                        <p class="small text-success mb-0">Kurulum iyi görünüyor — yayına veya canlı kullanıma hazırsınız.</p>
                    }
                    else if (Model.OnboardingStatus.IsLowScore)
                    {
                        <p class="small text-warning mb-0">
                            Kurulum skoru düşük.
                            @if (!string.IsNullOrWhiteSpace(Model.OnboardingStatus.NextBestActionTitle))
                            {
                                <span>Sıradaki: <strong>@Model.OnboardingStatus.NextBestActionTitle</strong></span>
                            }
                        </p>
                    }
                    else
                    {
                        <p class="small text-muted mb-0">
                            @if (!string.IsNullOrWhiteSpace(Model.OnboardingStatus.NextBestActionTitle))
                            {
                                <span>Sıradaki adım: <strong>@Model.OnboardingStatus.NextBestActionTitle</strong></span>
                            }
                            else
                            {
                                <span>Adımları tamamlamak için Kurulum Sihirbazı’nı açın.</span>
                            }
                        </p>
                    }
                </div>
                <div class="col-md-3 text-md-end">
                    <a href="/Business/Onboarding" class="btn btn-sm @(Model.OnboardingStatus.IsLowScore ? "btn-warning" : "btn-primary")">Kurulum Sihirbazı</a>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.GoLiveStatus is not null)
{
    <div class="panel-card mb-4 golive-dashboard-card">
        <div class="panel-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="h6 mb-0">Go-Live Durumu</h3>
            <span class="badge @Model.GoLiveStatus.HealthBadgeClass">@Model.GoLiveStatus.HealthLabel</span>
        </div>
        <div class="panel-card-body">
            <div class="row g-3 align-items-center">
                <div class="col-sm-3 col-md-2">
                    <div class="golive-score-ring golive-score-ring-sm" aria-label="Go-Live skoru @Model.GoLiveStatus.HealthScore">
                        <span class="golive-score-value">@Model.GoLiveStatus.HealthScore</span>
                    </div>
                </div>
                <div class="col-sm-9 col-md-7">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>Zorunlu adımlar</span>
                        <strong>@Model.GoLiveStatus.RequiredCompletedCount / @Model.GoLiveStatus.RequiredTotalCount</strong>
                    </div>
                    <div class="progress" style="height: 8px;" role="progressbar" aria-valuenow="@Model.GoLiveStatus.ProgressPercent" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar @(Model.GoLiveStatus.IsReadyToGoLive ? "bg-success" : "bg-primary")" style="width: @Model.GoLiveStatus.ProgressPercent%"></div>
                    </div>
                    @if (Model.GoLiveStatus.IsReadyToGoLive)
                    {
                        <p class="small text-success mb-0 mt-2">İşletmeniz yayına hazır görünüyor.</p>
                    }
                    else
                    {
                        <p class="small text-warning mb-0 mt-2">
                            Yayına hazır değilsiniz.
                            @if (!string.IsNullOrWhiteSpace(Model.GoLiveStatus.PrimaryMissingStepTitle))
                            {
                                <span>Önce şu adımı tamamlayın: <strong>@Model.GoLiveStatus.PrimaryMissingStepTitle</strong></span>
                            }
                            else
                            {
                                <span>Eksik adımları Go-Live Merkezi’nden tamamlayın.</span>
                            }
                        </p>
                    }
                </div>
                <div class="col-md-3 text-md-end">
                    <a href="/Business/GoLive" class="btn btn-sm btn-primary">Go-Live Merkezi’ne Git</a>
                </div>
            </div>
            @if (!Model.GoLiveStatus.IsReadyToGoLive)
            {
                <div class="alert alert-light border mt-3 mb-0 small">
                    Satış demosu veya test için <a href="/Business/DemoCenter">Demo Merkezi</a>’ni de kullanabilirsiniz.
                </div>
            }
        </div>
    </div>
}

@if (Model.Notifications.RecentItems.Count > 0 || Model.Notifications.UnreadCount > 0)
{
    <div class="panel-card mb-4">
        <div class="panel-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="h6 mb-0">Bildirimler</h3>
            <div class="d-flex gap-2 align-items-center">
                @if (Model.Notifications.UnreadCount > 0)
                {
                    <span class="badge bg-primary">@Model.Notifications.UnreadCount okunmamış</span>
                }
                <a href="/Business/Notifications" class="btn btn-sm btn-outline-primary">Bildirim Merkezi</a>
            </div>
        </div>
        <div class="panel-card-body p-0">
            @if (Model.Notifications.RecentItems.Count == 0)
            {
                <p class="text-muted small mb-0 p-3">Şu an yeni bildiriminiz yok.</p>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var n in Model.Notifications.RecentItems)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-start gap-2">
                            <div>
                                <div class="fw-semibold small">@n.Title</div>
                                <div class="text-muted small">@n.Message</div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(n.ActionUrl))
                            {
                                <a href="@n.ActionUrl" class="btn btn-sm btn-outline-secondary">Git</a>
                            }
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
}

@if (Model.Subscription.HasValidSubscription)
{
    <div id="live-orders-root"
         data-live-orders="true"
         data-live-url="/Business/Orders/LiveSummary"
         data-live-page-key="dashboard"
         data-initial-latest-order-id="@(Model.OrderSummary.LatestOrderId?.ToString() ?? "")"
         data-initial-pending-count="@Model.OrderSummary.PendingCount">
    </div>

    <div id="live-new-order-alert" class="alert alert-warning d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4" hidden role="alert">
        <div>
            <strong>Yeni sipariş var.</strong> Siparişleri görüntüleyin.
        </div>
        <a href="/Business/Orders" id="live-dashboard-orders-link" class="btn btn-sm btn-warning">Siparişlere Git</a>
    </div>
}

<div class="panel-card mb-4">
    <div class="panel-card-header d-flex justify-content-between align-items-center">
        <h3 class="h6 mb-0">Abonelik Özeti</h3>
        @if (Model.IsBusinessOwner)
        {
            <a href="/Business/Billing" class="btn btn-sm btn-outline-primary">Detay</a>
        }
    </div>
    <div class="panel-card-body">
        <dl class="row mb-3 small">
            <dt class="col-sm-3 col-md-2">Plan</dt>
            <dd class="col-sm-9 col-md-4 fw-semibold">@Model.Subscription.PlanName</dd>
            <dt class="col-sm-3 col-md-2">Durum</dt>
            <dd class="col-sm-9 col-md-4">
                <span class="badge @Model.Subscription.StatusCssClass">@Model.Subscription.StatusText</span>
            </dd>
            <dt class="col-sm-3 col-md-2">Kalan Gün</dt>
            <dd class="col-sm-9 col-md-4">
                @(Model.Subscription.DaysRemaining.HasValue ? $"{Model.Subscription.DaysRemaining} gün" : "Süresiz")
            </dd>
        </dl>
        <h4 class="h6 mb-3">Kullanım / Limit</h4>
        <partial name="_PlanUsageSummary" model="Model.PlanUsage" />
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Bugünkü Ciro</div>
            <div class="stat-value fs-5" data-live-today-revenue>@Model.OrderSummary.TodayRevenue.ToString("N2", culture) ₺</div>
            <div class="text-muted small mt-1">@Model.OrderSummary.TodayOrderCount sipariş</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Son 7 Gün Ciro</div>
            <div class="stat-value fs-5">@Model.OrderSummary.Last7DaysRevenue.ToString("N2", culture) ₺</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Aylık Ciro</div>
            <div class="stat-value fs-5">@Model.OrderSummary.MonthlyRevenue.ToString("N2", culture) ₺</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Ortalama Sepet Tutarı</div>
            <div class="stat-value fs-5">@Model.OrderSummary.AverageOrderAmount.ToString("N2", culture) ₺</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6">
        <div class="stat-card h-100 border-warning-subtle">
            <div class="stat-label">Bekleyen Sipariş</div>
            <div class="stat-value text-warning" data-live-pending-count>@Model.OrderSummary.PendingCount</div>
            @if (Model.Subscription.HasValidSubscription)
            {
                <a href="/Business/Orders?status=Pending" class="small">Siparişleri gör →</a>
            }
        </div>
    </div>
    <div class="col-sm-6">
        <div class="stat-card h-100 border-info-subtle">
            <div class="stat-label">Hazırlanan Sipariş</div>
            <div class="stat-value text-info" data-live-preparing-count>@Model.OrderSummary.PreparingCount</div>
            @if (Model.Subscription.HasValidSubscription)
            {
                <a href="/Business/Orders/Kitchen" class="small">Mutfak moduna git →</a>
            }
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="panel-card mb-4">
            <div class="panel-card-header d-flex justify-content-between align-items-center">
                <h3 class="h6 mb-0">Sipariş Durum Dağılımı</h3>
                <span class="badge bg-light text-dark">@statusTotal toplam</span>
            </div>
            <div class="panel-card-body">
                @if (statusTotal == 0)
                {
                    <p class="text-muted mb-0">Henüz sipariş yok.</p>
                }
                else
                {
                    <div class="dashboard-status-distribution">
                        <div class="dashboard-status-row">
                            <div class="dashboard-status-label">
                                <span class="badge bg-warning text-dark">Beklemede</span>
                                <span class="dashboard-status-count">@Model.StatusDistribution.PendingCount</span>
                            </div>
                            <div class="progress dashboard-status-bar" role="progressbar" aria-valuenow="@StatusPercent(Model.StatusDistribution.PendingCount)" aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar bg-warning" style="width: @StatusPercent(Model.StatusDistribution.PendingCount)%"></div>
                            </div>
                        </div>
                        <div class="dashboard-status-row">
                            <div class="dashboard-status-label">
                                <span class="badge bg-info text-dark">Hazırlanıyor</span>
                                <span class="dashboard-status-count">@Model.StatusDistribution.PreparingCount</span>
                            </div>
                            <div class="progress dashboard-status-bar">
                                <div class="progress-bar bg-info" style="width: @StatusPercent(Model.StatusDistribution.PreparingCount)%"></div>
                            </div>
                        </div>
                        <div class="dashboard-status-row">
                            <div class="dashboard-status-label">
                                <span class="badge bg-success">Tamamlandı</span>
                                <span class="dashboard-status-count">@Model.StatusDistribution.CompletedCount</span>
                            </div>
                            <div class="progress dashboard-status-bar">
                                <div class="progress-bar bg-success" style="width: @StatusPercent(Model.StatusDistribution.CompletedCount)%"></div>
                            </div>
                        </div>
                        <div class="dashboard-status-row mb-0">
                            <div class="dashboard-status-label">
                                <span class="badge bg-secondary">İptal</span>
                                <span class="dashboard-status-count">@Model.StatusDistribution.CancelledCount</span>
                            </div>
                            <div class="progress dashboard-status-bar">
                                <div class="progress-bar bg-secondary" style="width: @StatusPercent(Model.StatusDistribution.CancelledCount)%"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="panel-card">
            <div class="panel-card-header d-flex justify-content-between align-items-center">
                <h3 class="h6 mb-0">Son Siparişler</h3>
                <a href="/Business/Orders" class="btn btn-sm btn-outline-primary">Tümünü Gör</a>
            </div>
            <div class="panel-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sipariş No</th>
                                <th>Müşteri</th>
                                <th>Tutar</th>
                                <th>Durum</th>
                                <th>Tarih</th>
                                <th class="text-end">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.RecentOrders.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Henüz sipariş yok.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var order in Model.RecentOrders)
                            {
                                <tr>
                                    <td class="fw-semibold">@order.OrderNumber</td>
                                    <td>@(order.CustomerName ?? "-")</td>
                                    <td>@order.TotalAmount.ToString("N2", culture) ₺</td>
                                    <td>
                                        <span class="badge @OrderDisplayHelper.GetStatusBadgeClass(order.Status)">
                                            @OrderDisplayHelper.GetStatusLabel(order.Status)
                                        </span>
                                    </td>
                                    <td>@order.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm", culture)</td>
                                    <td class="text-end">
                                        <a href="/Business/Orders/Details/@order.Id" class="btn btn-sm btn-outline-primary">Detay</a>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="panel-card mb-4">
            <div class="panel-card-header d-flex justify-content-between align-items-center">
                <h3 class="h6 mb-0">En Çok Satan Ürünler</h3>
                <a href="/Business/Reports/Products" class="btn btn-sm btn-outline-primary">Rapor</a>
            </div>
            <div class="panel-card-body p-0">
                @if (!Model.TopProducts.Any())
                {
                    <p class="text-muted mb-0 p-3">Henüz satış verisi yok.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush dashboard-top-products">
                        @foreach (var (product, index) in Model.TopProducts.Select((p, i) => (p, i)))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-start gap-2">
                                <div class="min-w-0">
                                    <span class="badge bg-light text-dark me-1">@(index + 1)</span>
                                    <span class="fw-semibold">@product.ProductName</span>
                                    <div class="text-muted small">@product.QuantitySold adet</div>
                                </div>
                                <span class="fw-semibold text-nowrap">@product.TotalRevenue.ToString("N2", culture) ₺</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <div class="panel-card mb-4">
            <div class="panel-card-header d-flex justify-content-between align-items-center">
                <h3 class="h6 mb-0">Kampanya Etkisi (Bu Ay)</h3>
                <a href="/Business/Reports/Campaigns?period=thismonth" class="btn btn-sm btn-outline-primary">Rapor</a>
            </div>
            <div class="panel-card-body">
                <dl class="row mb-0 small">
                    <dt class="col-7">Kampanyalı sipariş</dt>
                    <dd class="col-5 text-end fw-semibold">@Model.CampaignSummary.MonthCampaignOrderCount</dd>
                    <dt class="col-7">Toplam indirim</dt>
                    <dd class="col-5 text-end fw-semibold">@Model.CampaignSummary.MonthTotalDiscount.ToString("N2", culture) ₺</dd>
                    <dt class="col-7">En çok kullanılan</dt>
                    <dd class="col-5 text-end fw-semibold">@(Model.CampaignSummary.TopCampaignNameThisMonth ?? "-")</dd>
                </dl>
            </div>
        </div>

        <div class="panel-card mb-4">
            <div class="panel-card-header">
                <h3 class="h6 mb-0">Hızlı Aksiyonlar</h3>
            </div>
            <div class="panel-card-body d-grid gap-2">
                <a href="/Business/GoLive" class="btn btn-success">Go-Live Merkezi</a>
                <a href="/Business/DemoCenter" class="btn btn-outline-info">Demo Merkezi</a>
                <a href="/Business/Notifications" class="btn btn-outline-warning">Bildirim Merkezi</a>
                <a href="/Business/AuditLogs" class="btn btn-outline-dark">Aktivite Geçmişi</a>
                <a href="/Business/Customers/Insights" class="btn btn-outline-primary">Müşteri CRM</a>
                <a href="/Business/MenuStudio" class="btn btn-outline-primary">Menü Stüdyosu</a>
                <a href="/Business/Orders/Kitchen" class="btn btn-outline-secondary">Mutfak Modunu Aç</a>
                <a href="/Business/Orders" class="btn btn-outline-primary">Siparişleri Yönet</a>
                <a href="/Business/Products/Create" class="btn btn-outline-primary">Yeni Ürün Ekle</a>
                <a href="/Business/Campaigns/Create" class="btn btn-outline-primary">Yeni Kampanya</a>
                <a href="/m/@Model.BusinessSlug" class="btn btn-outline-primary" target="_blank" rel="noopener">QR Menüyü Gör</a>
                <a href="/Business/QrMenu/Print" class="btn btn-outline-primary">QR Afiş Yazdır</a>
                @if (Model.IsBusinessOwner)
                {
                    <a href="/Business/Settings" class="btn btn-outline-secondary">İşletme Ayarları</a>
                }
            </div>
        </div>

        <div class="panel-card">
            <div class="panel-card-header d-flex justify-content-between align-items-center">
                <h3 class="h6 mb-0">Menü Özeti</h3>
            </div>
            <div class="panel-card-body">
                <dl class="row mb-0 small">
                    <dt class="col-7">Aktif Kategori</dt>
                    <dd class="col-5 text-end fw-semibold">@Model.ActiveCategoryCount / @Model.TotalCategoryCount</dd>
                    <dt class="col-7">Aktif Ürün</dt>
                    <dd class="col-5 text-end fw-semibold">@Model.ActiveProductCount / @Model.TotalProductCount</dd>
                    <dt class="col-7">Toplam Müşteri</dt>
                    <dd class="col-5 text-end fw-semibold">@Model.TotalCustomerCount</dd>
                    <dt class="col-7">Aktif Müşteri</dt>
                    <dd class="col-5 text-end fw-semibold">@Model.ActiveCustomerCount</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@if (Model.Subscription.HasValidSubscription)
{
    @section Scripts {
        <script src="~/js/business-orders-live.js" asp-append-version="true"></script>
    }
}
