@model RewardRedeemViewModel

@{

    ViewData["Title"] = "Ödül Kullan";

    ViewData["Subtitle"] = Model.RewardName;

}



<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="h4 mb-1">Ödül Kullan</h2>

        <p class="text-muted mb-0">@Model.RewardName — @Model.RequiredPoints puan düşülecek</p>

    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">Geri Dön</a>

</div>



<div class="panel-card">

    <div class="panel-card-body">

        <div class="alert alert-info py-2 mb-4">

            <strong>@Model.RewardName</strong> ödülünü kullanmak için müşteri seçin.

            Bu işlem <strong>@Model.RequiredPoints puan</strong> düşer ve puan hareketi kaydı oluşturur.

        </div>



        @if (!Model.AvailableCustomers.Any())

        {

            <div class="alert alert-warning mb-0">

                Aktif müşteri bulunamadı. Önce <a href="/Business/Customers/Create">müşteri ekleyin</a>.

            </div>

        }

        else

        {

            <form asp-action="Redeem" asp-route-id="@Model.RewardId" method="post">

                <input type="hidden" asp-for="RewardId" />

                <input type="hidden" asp-for="RewardName" />

                <input type="hidden" asp-for="RequiredPoints" />



                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>



                <div class="row g-3">

                    <div class="col-md-8">

                        <label asp-for="CustomerId" class="form-label"></label>

                        <select asp-for="CustomerId" asp-items="Model.AvailableCustomers" class="form-select">

                            <option value="">Müşteri seçin</option>

                        </select>

                        <div class="form-text">Listede müşterinin mevcut puanı gösterilir.</div>

                        <span asp-validation-for="CustomerId" class="text-danger small"></span>

                    </div>

                    <div class="col-md-4">

                        <label class="form-label">Gerekli Puan</label>

                        <div class="form-control-plaintext fw-semibold">@Model.RequiredPoints puan</div>

                    </div>

                    <div class="col-12">

                        <label asp-for="Description" class="form-label"></label>

                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Boş bırakılırsa otomatik açıklama oluşturulur."></textarea>

                        <span asp-validation-for="Description" class="text-danger small"></span>

                    </div>

                </div>



                <div class="d-flex gap-2 mt-4">

                    <button type="submit" class="btn btn-success">Ödülü Kullan</button>

                    <a asp-action="Details" asp-route-id="@Model.RewardId" class="btn btn-outline-secondary">İptal</a>

                </div>

            </form>

        }

    </div>

</div>



@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}


