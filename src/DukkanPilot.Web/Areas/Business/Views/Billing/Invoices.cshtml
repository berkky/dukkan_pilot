@model DukkanPilot.Web.Areas.Business.Models.BusinessBillingLedgerViewModel
@using DukkanPilot.Web.Helpers
@using System.Globalization
@{
    ViewData["Title"] = "Tahsilat Kayıtlarım";
    ViewData["Subtitle"] = "İç tahsilat takibi";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
}

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h2 class="h4 mb-1">Tahsilat Kayıtlarım</h2>
        <p class="text-muted mb-0">Ödeme/tahsilat takip kayıtları (resmi belge değildir).</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Business/Billing" class="btn btn-outline-secondary btn-sm">Abonelik</a>
        <a href="/Business/Billing/Requests" class="btn btn-outline-primary btn-sm">Satış Taleplerim</a>
    </div>
</div>

<div class="alert alert-light border small mb-4">@Model.DisclaimerText</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="panel-card h-100 border-primary mb-0">
            <div class="panel-card-body">
                <div class="text-muted small mb-1">Açık tutar</div>
                <div class="h4 mb-0 text-primary">@BillingDisplayHelper.FormatMoney(Model.OpenAmount, "TRY")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="panel-card h-100 border-danger mb-0">
            <div class="panel-card-body">
                <div class="text-muted small mb-1">Gecikmiş</div>
                <div class="h4 mb-0 text-danger">@BillingDisplayHelper.FormatMoney(Model.OverdueAmount, "TRY")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="panel-card h-100 border-success mb-0">
            <div class="panel-card-body">
                <div class="text-muted small mb-1">Bu ay ödenen</div>
                <div class="h4 mb-0 text-success">@BillingDisplayHelper.FormatMoney(Model.PaidThisMonth, "TRY")</div>
                @if (Model.NextDueDateUtc.HasValue)
                {
                    <div class="small text-muted mt-1">Sonraki vade: @Model.NextDueDateUtc.Value.ToLocalTime().ToString("dd.MM.yyyy", culture)</div>
                }
            </div>
        </div>
    </div>
</div>

<div class="panel-card mb-4">
    <div class="panel-card-header d-flex justify-content-between align-items-center">
        <h3 class="h6 mb-0">Invoice listesi</h3>
        <a class="btn btn-sm btn-outline-secondary" href="/Business/Billing/Payments">Ödemeler</a>
    </div>
    <div class="panel-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                <tr>
                    <th>No</th>
                    <th>Başlık</th>
                    <th>Kesim</th>
                    <th>Vade</th>
                    <th class="text-end">Toplam</th>
                    <th>Status</th>
                    <th>Payment</th>
                    <th>Not</th>
                </tr>
                </thead>
                <tbody>
                @if (!Model.Invoices.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Kayıt yok.</td></tr>
                }
                else
                {
                    foreach (var i in Model.Invoices)
                    {
                        <tr>
                            <td class="fw-semibold">@i.InvoiceNumber</td>
                            <td class="small">@i.Title</td>
                            <td class="small">@i.IssueDate.ToLocalTime().ToString("dd.MM.yyyy", culture)</td>
                            <td class="small">
                                @i.DueDate.ToLocalTime().ToString("dd.MM.yyyy", culture)
                                <div class="text-muted small">@BillingDisplayHelper.GetDueStatusText(i.DueDate)</div>
                            </td>
                            <td class="text-end fw-semibold">@BillingDisplayHelper.FormatMoney(i.TotalAmount, i.Currency)</td>
                            <td><span class="badge @BillingDisplayHelper.GetInvoiceStatusBadgeClass(i.Status)">@BillingDisplayHelper.GetInvoiceStatusLabel(i.Status)</span></td>
                            <td><span class="badge @BillingDisplayHelper.GetPaymentStatusBadgeClass(i.PaymentStatus)">@BillingDisplayHelper.GetPaymentStatusLabel(i.PaymentStatus)</span></td>
                            <td class="small text-muted">@(!string.IsNullOrWhiteSpace(i.BusinessVisibleNote) ? i.BusinessVisibleNote : "-")</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

