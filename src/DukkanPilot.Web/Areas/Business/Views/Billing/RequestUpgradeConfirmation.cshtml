@model PlanUpgradeRequestViewModel
@{
    ViewData["Title"] = "Talep Oluşturuldu";
    ViewData["Subtitle"] = "Plan yükseltme talebi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-1">Talep Oluşturuldu</h2>
        <p class="text-muted mb-0">Plan yükseltme talebiniz hazır</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Billing'e Dön</a>
</div>

<div class="panel-card">
    <div class="panel-card-header">
        <h3 class="h6 mb-0">Talep Metni</h3>
    </div>
    <div class="panel-card-body">
        <div class="alert alert-success small">
            Plan yükseltme talebi oluşturuldu. Aşağıdaki metni kopyalayıp yöneticiye iletebilirsiniz.
        </div>

        <label for="requestMessage" class="form-label">Hazır talep metni</label>
        <textarea id="requestMessage" class="form-control font-monospace" rows="10" readonly>@Model.RequestMessage</textarea>

        <div class="d-flex flex-wrap gap-2 mt-3">
            <button type="button" class="btn btn-outline-primary btn-sm" onclick="copyRequestMessage()">Metni Kopyala</button>
            <a asp-action="Index" class="btn btn-primary btn-sm">Billing'e Dön</a>
        </div>

        <p class="text-muted small mt-3 mb-0">
            Bu aşamada talep veritabanına kaydedilmez; plan otomatik değişmez. Admin,
            <code>/Admin/Businesses/Subscription/{businessId}</code> ekranından aboneliği manuel günceller.
        </p>
    </div>
</div>

@section Scripts {
    <script>
        function copyRequestMessage() {
            const textarea = document.getElementById('requestMessage');
            textarea.select();
            textarea.setSelectionRange(0, textarea.value.length);
            navigator.clipboard.writeText(textarea.value).catch(function () {
                document.execCommand('copy');
            });
        }
    </script>
}
