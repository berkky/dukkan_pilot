@model OrderKitchenViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Mutfak Modu";
    ViewData["Subtitle"] = "Operasyon";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h2 class="h4 mb-1">Mutfak / Operasyon Modu</h2>
        <p class="text-muted mb-0">Bu ekran açıkken yeni siparişleri takip edebilirsiniz.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <button type="button" id="live-sound-toggle" class="btn btn-outline-secondary">Sesli uyarıyı etkinleştir</button>
        <button type="button" id="kitchen-refresh-btn" class="btn btn-outline-primary">Yenile</button>
        <a asp-action="Index" class="btn btn-secondary">Sipariş Listesine Dön</a>
    </div>
</div>

@if (TempData["Success"] is string successMessage)
{
    <div class="alert alert-success small">@successMessage</div>
}
@if (TempData["Error"] is string errorMessage)
{
    <div class="alert alert-danger small">@errorMessage</div>
}

<div id="live-orders-root"
     data-live-orders="true"
     data-live-url="/Business/Orders/LiveSummary"
     data-live-page-key="orders-kitchen"
     data-initial-latest-order-id="@(Model.LatestOrderId?.ToString() ?? "")"
     data-initial-pending-count="@Model.PendingCount">
</div>

<div id="live-new-order-alert" class="alert alert-warning d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3" hidden role="alert">
    <div>
        <strong>Yeni sipariş var.</strong> Ekranı yenileyerek görüntüleyebilirsiniz.
    </div>
    <button type="button" id="live-reload-btn" class="btn btn-sm btn-warning">Ekranı Yenile</button>
</div>

@if (Model.PendingCount == 0 && Model.PreparingCount == 0 && Model.CompletedTodayCount == 0 && !Model.CancelledTodayOrders.Any())
{
    @await Html.PartialAsync("~/Views/Shared/_EmptyState.cshtml", new EmptyStateViewModel
    {
        Icon = "👨‍🍳",
        Title = "Mutfak şu an boş",
        Description = "Bekleyen veya hazırlanan sipariş yok. Yeni sipariş geldiğinde bu ekranda görünecek.",
        PrimaryActionText = "Sipariş Listesi",
        PrimaryActionUrl = "/Business/Orders",
        SecondaryActionText = "Go-Live Merkezi",
        SecondaryActionUrl = "/Business/GoLive",
        HelpText = "Bu ekranı açık tutarak canlı sipariş takibi yapabilirsiniz."
    })
}

<div class="row g-3 mb-3">
    <div class="col-md-3 col-6">
        <div class="border rounded p-2 text-center">
            <div class="small text-muted">Bekleyen</div>
            <div class="fs-4 fw-bold text-warning" data-live-pending-count>@Model.PendingCount</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="border rounded p-2 text-center">
            <div class="small text-muted">Hazırlanıyor</div>
            <div class="fs-4 fw-bold text-info" data-live-preparing-count>@Model.PreparingCount</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="border rounded p-2 text-center">
            <div class="small text-muted">Bugün Tamamlanan</div>
            <div class="fs-4 fw-bold text-success">@Model.CompletedTodayCount</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="border rounded p-2 text-center">
            <div class="small text-muted">Bugünkü Ciro</div>
            <div class="fs-4 fw-bold" data-live-today-revenue>@Model.TodayRevenue.ToString("N2", culture) ₺</div>
        </div>
    </div>
</div>

<div class="row g-4 kitchen-board">
    <div class="col-lg-4">
        <div class="kitchen-column">
            <div class="kitchen-column-header bg-warning-subtle">
                <h3 class="h6 mb-0">Bekleyen Siparişler (<span data-live-pending-count>@Model.PendingCount</span>)</h3>
            </div>
            <div class="kitchen-column-body">
                @if (!Model.PendingOrders.Any())
                {
                    <p class="text-muted small mb-0 py-3 text-center">Bekleyen sipariş yok.</p>
                }
                else
                {
                    foreach (var order in Model.PendingOrders)
                    {
                        <partial name="_KitchenOrderCard" model="order" />
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="kitchen-column">
            <div class="kitchen-column-header bg-info-subtle">
                <h3 class="h6 mb-0">Hazırlanıyor (<span data-live-preparing-count>@Model.PreparingCount</span>)</h3>
            </div>
            <div class="kitchen-column-body">
                @if (!Model.PreparingOrders.Any())
                {
                    <p class="text-muted small mb-0 py-3 text-center">Hazırlanan sipariş yok.</p>
                }
                else
                {
                    foreach (var order in Model.PreparingOrders)
                    {
                        <partial name="_KitchenOrderCard" model="order" />
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="kitchen-column">
            <div class="kitchen-column-header bg-success-subtle">
                <h3 class="h6 mb-0">Bugün Tamamlananlar (@Model.CompletedTodayCount)</h3>
            </div>
            <div class="kitchen-column-body">
                @if (!Model.CompletedTodayOrders.Any())
                {
                    <p class="text-muted small mb-0 py-3 text-center">Bugün tamamlanan sipariş yok.</p>
                }
                else
                {
                    foreach (var order in Model.CompletedTodayOrders)
                    {
                        <partial name="_KitchenOrderCard" model="order" />
                    }
                }
            </div>
        </div>
    </div>
</div>

@if (Model.CancelledTodayOrders.Any())
{
    <div class="kitchen-column mt-4">
        <div class="kitchen-column-header bg-secondary-subtle">
            <h3 class="h6 mb-0">Bugün İptal Edilenler (@Model.CancelledTodayOrders.Count)</h3>
        </div>
        <div class="kitchen-column-body kitchen-column-body-compact">
            <div class="row g-3">
                @foreach (var order in Model.CancelledTodayOrders)
                {
                    <div class="col-md-6 col-xl-4">
                        <partial name="_KitchenOrderCard" model="order" />
                    </div>
                }
            </div>
        </div>
    </div>
}

@section Styles {
    <style>
        .kitchen-board {
            align-items: flex-start;
        }

        .kitchen-column {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 0.75rem;
            overflow: hidden;
            height: 100%;
        }

        .kitchen-column-header {
            padding: 0.875rem 1rem;
            border-bottom: 1px solid #e2e8f0;
        }

        .kitchen-column-body {
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            max-height: 70vh;
            overflow-y: auto;
        }

        .kitchen-column-body-compact {
            max-height: none;
        }

        .kitchen-order-card {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 0.75rem;
            padding: 1rem;
        }

        .kitchen-order-number {
            font-weight: 700;
            font-size: 1.05rem;
        }

        .kitchen-order-items li {
            padding: 0.15rem 0;
            line-height: 1.35;
        }

        .kitchen-order-total {
            color: #0f172a;
            font-size: 1.1rem;
        }

        @@media (min-width: 992px) {
            .kitchen-order-card .btn-lg {
                min-height: 3rem;
                font-size: 1rem;
            }
        }
    </style>
}

@section Scripts {
    <script src="~/js/business-orders-live.js" asp-append-version="true"></script>
    <script>
        (function () {
            const refreshBtn = document.getElementById('kitchen-refresh-btn');
            if (refreshBtn) {
                refreshBtn.addEventListener('click', function () {
                    window.location.reload();
                });
            }
        })();
    </script>
}
