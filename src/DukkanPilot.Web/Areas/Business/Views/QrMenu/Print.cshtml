@model QrMenuPrintViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.PrintTitle — QR Menü Afişi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/qr-menu-print.css" asp-append-version="true" />
</head>
<body class="qr-print-body">
    <div class="qr-print-toolbar no-print">
        <button type="button" class="btn btn-primary" id="printBtn">Yazdır</button>
        <a href="/Business/QrMenu" class="btn btn-outline-secondary">QR Menüye Dön</a>
    </div>

    <div class="qr-print-page" style="--qr-print-theme: @Model.ThemeColor;">
        <div class="qr-print-poster">
            <header class="qr-print-header">
                @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
                {
                    <img src="@Model.LogoUrl"
                         alt="@Model.BusinessName"
                         class="qr-print-logo"
                         onerror="this.hidden=true; this.nextElementSibling.hidden=false;" />
                    <div class="qr-print-logo-placeholder" hidden aria-hidden="true">☕</div>
                }
                else
                {
                    <div class="qr-print-logo-placeholder" aria-hidden="true">☕</div>
                }
                <h1 class="qr-print-title">@Model.PrintTitle</h1>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="qr-print-subtitle">@Model.Description</p>
                }
                else
                {
                    <p class="qr-print-subtitle">@Model.PrintSubtitle</p>
                }
            </header>

            <div class="qr-print-qr-wrap">
                <div id="qrcode-print"></div>
            </div>

            <p class="qr-print-instructions">Menümüzü görmek için QR kodu okutun</p>
            <p class="qr-print-instructions-secondary">Siparişinizi WhatsApp üzerinden kolayca iletin</p>

            <div class="qr-print-link">@Model.PublicMenuPath</div>

            @if (!string.IsNullOrWhiteSpace(Model.Address) || !string.IsNullOrWhiteSpace(Model.Phone))
            {
                <div class="qr-print-contact">
                    @if (!string.IsNullOrWhiteSpace(Model.Address))
                    {
                        <div class="qr-print-contact-item">📍 @Model.Address</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Phone))
                    {
                        <div class="qr-print-contact-item">📞 @Model.Phone</div>
                    }
                </div>
            }
        </div>

        <footer class="qr-print-footer">
            DükkanPilot ile oluşturuldu
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script>
        (function () {
            const qrPayload = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.QrPayload));

            new QRCode(document.getElementById('qrcode-print'), {
                text: qrPayload,
                width: 260,
                height: 260,
                colorDark: '#000000',
                colorLight: '#ffffff',
                correctLevel: QRCode.CorrectLevel.H
            });

            document.getElementById('printBtn').addEventListener('click', function () {
                window.print();
            });
        })();
    </script>
</body>
</html>
