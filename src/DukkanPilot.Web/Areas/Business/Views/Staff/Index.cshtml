@model IEnumerable<StaffListViewModel>
@using System.Globalization

@{
    ViewData["Title"] = "Personel";
    ViewData["Subtitle"] = "Personel listesi";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-1">Personel</h2>
        <p class="text-muted mb-0">İşletme personel kullanıcıları</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Yeni Personel</a>
</div>

<div class="panel-card">
    <div class="panel-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Ad Soyad</th>
                        <th>E-posta</th>
                        <th>Rol</th>
                        <th>Durum</th>
                        <th>Oluşturulma</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Henüz personel kaydı yok.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td class="fw-semibold">@item.FullName</td>
                            <td>@item.Email</td>
                            <td>
                                <span class="badge @StaffDisplayHelper.GetRoleBadgeClass(item.BusinessRole)">
                                    @StaffDisplayHelper.GetRoleLabel(item.BusinessRole)
                                </span>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm", culture)</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Detay</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                                @if (item.IsActive)
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Pasif Yap</a>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
