@model DukkanPilot.Web.Areas.Business.Models.AdminAuditLogIndexViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Platform Aktivite Logları";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
    string SeverityClass(string s) => s switch
    {
        "Critical" => "bg-danger",
        "Warning" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2 class="h4 mb-1">Platform Aktivite Logları</h2>
        <p class="text-muted mb-0">Admin, Business, Account ve Public kritik işlem kayıtları</p>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/_HelpCard.cshtml", new HelpCardViewModel
{
    Title = "Bu ekran ne işe yarar?",
    Description = "Platform genelindeki kritik işlemleri işletme, alan ve severity bazında izleyin. Destek ve denetim için kullanın.",
    ActionText = "Platform Bildirimleri",
    ActionUrl = "/Admin/Notifications"
})

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Bugün</div>
            <div class="stat-value">@Model.TodayCount</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Son 7 Gün</div>
            <div class="stat-value">@Model.Last7DaysCount</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Admin (7g)</div>
            <div class="stat-value">@Model.AdminActionCount</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Uyarı / Kritik (7g)</div>
            <div class="stat-value">@Model.CriticalCount</div>
        </div>
    </div>
</div>

<div class="panel-card mb-4">
    <div class="panel-card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small">BusinessId</label>
                <input type="number" name="businessId" value="@Model.BusinessId" class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Area</label>
                <select name="area" class="form-select form-select-sm">
                    <option value="">Tümü</option>
                    @foreach (var a in new[] { "Admin", "Business", "Account", "Public" })
                    {
                        if (Model.Area == a)
                        {
                            <option value="@a" selected>@a</option>
                        }
                        else
                        {
                            <option value="@a">@a</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Ara</label>
                <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Aksiyon</label>
                <input type="text" name="action" value="@Model.Action" class="form-control form-control-sm" />
            </div>
            <div class="col-md-1">
                <label class="form-label small">Severity</label>
                <select name="severity" class="form-select form-select-sm">
                    <option value="">Tümü</option>
                    @if (Model.Severity == "Info") { <option value="Info" selected>Info</option> } else { <option value="Info">Info</option> }
                    @if (Model.Severity == "Warning") { <option value="Warning" selected>Warning</option> } else { <option value="Warning">Warning</option> }
                    @if (Model.Severity == "Critical") { <option value="Critical" selected>Critical</option> } else { <option value="Critical">Critical</option> }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Kullanıcı</label>
                <input type="text" name="userEmail" value="@Model.UserEmail" class="form-control form-control-sm" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-sm btn-primary w-100">Filtrele</button>
            </div>
        </form>
    </div>
</div>

<div class="panel-card">
    <div class="panel-card-header d-flex justify-content-between">
        <h3 class="h6 mb-0">Kayıtlar (@Model.TotalCount)</h3>
        <span class="small text-muted">Sayfa @Model.Page / @Math.Max(1, Model.TotalPages)</span>
    </div>
    <div class="panel-card-body p-0">
        @if (!Model.Items.Any())
        {
            if (Model.TotalCount == 0 && string.IsNullOrWhiteSpace(Model.Search) && string.IsNullOrWhiteSpace(Model.Action) && string.IsNullOrWhiteSpace(Model.Severity) && string.IsNullOrWhiteSpace(Model.UserEmail) && string.IsNullOrWhiteSpace(Model.Area) && !Model.BusinessId.HasValue)
            {
                @await Html.PartialAsync("~/Views/Shared/_EmptyState.cshtml", new EmptyStateViewModel
                {
                    Icon = "📝",
                    Title = "Henüz platform aktivitesi yok",
                    Description = "Admin ve işletme panellerinde kritik işlemler yapıldıkça kayıtlar burada görünür.",
                    PrimaryActionText = "Admin Dashboard",
                    PrimaryActionUrl = "/Admin/Dashboard",
                    HelpText = "Kayıtlar otomatik oluşur."
                })
            }
            else
            {
                <p class="text-muted mb-0 p-4 text-center">Filtreye uygun aktivite kaydı bulunamadı.</p>
            }
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Tarih</th>
                            <th>Business</th>
                            <th>User</th>
                            <th>Area</th>
                            <th>Action</th>
                            <th>Summary</th>
                            <th>Severity</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="text-nowrap small">@item.CreatedAtUtc.ToLocalTime().ToString("g", culture)</td>
                            <td class="small">
                                @if (item.BusinessId.HasValue)
                                {
                                    <a href="/Admin/Businesses/Details/@item.BusinessId">@(item.BusinessName ?? $"#{item.BusinessId}")</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="small">@(item.UserEmail ?? "-")</td>
                            <td><span class="badge bg-light text-dark border">@item.Area</span></td>
                            <td><code class="small">@item.Action</code></td>
                            <td class="small">
                                @item.Summary
                                @if (!string.IsNullOrWhiteSpace(item.MetadataJson))
                                {
                                    <details class="mt-1">
                                        <summary class="text-muted">Metadata</summary>
                                        <pre class="small mb-0 mt-1" style="white-space: pre-wrap; max-width: 24rem;">@item.MetadataJson</pre>
                                    </details>
                                }
                            </td>
                            <td><span class="badge @SeverityClass(item.Severity)">@item.Severity</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm">
            @for (var p = 1; p <= Model.TotalPages && p <= 20; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link"
                       asp-route-page="@p"
                       asp-route-businessId="@Model.BusinessId"
                       asp-route-search="@Model.Search"
                       asp-route-area="@Model.Area"
                       asp-route-action="@Model.Action"
                       asp-route-severity="@Model.Severity"
                       asp-route-userEmail="@Model.UserEmail">@p</a>
                </li>
            }
        </ul>
    </nav>
}
