@model AdminSupportListViewModel
@using System.Globalization
@using DukkanPilot.Web.Helpers
@{
    ViewData["Title"] = "Destek Talepleri";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
}

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
    <div>
        <h2 class="h4 mb-1">Destek Talepleri</h2>
        <p class="text-muted mb-0">İşletme destek ve geri bildirim talepleri</p>
    </div>
    <a href="/Admin/HelpCenter/Article/destek-talepleri-yonetimi" class="btn btn-outline-primary btn-sm">Destek rehberi</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-2"><div class="panel-card h-100"><div class="panel-card-body text-center"><div class="fw-bold fs-4">@Model.Summary.NewCount</div><div class="small text-muted">Yeni</div></div></div></div>
    <div class="col-6 col-md-2"><div class="panel-card h-100"><div class="panel-card-body text-center"><div class="fw-bold fs-4">@Model.Summary.OpenOrInProgressCount</div><div class="small text-muted">Açık / İşleniyor</div></div></div></div>
    <div class="col-6 col-md-2"><div class="panel-card h-100"><div class="panel-card-body text-center"><div class="fw-bold fs-4">@Model.Summary.WaitingAdminCount</div><div class="small text-muted">Admin bekliyor</div></div></div></div>
    <div class="col-6 col-md-2"><div class="panel-card h-100"><div class="panel-card-body text-center"><div class="fw-bold fs-4 text-danger">@Model.Summary.UrgentOrHighCount</div><div class="small text-muted">Acil / Yüksek</div></div></div></div>
    <div class="col-6 col-md-2"><div class="panel-card h-100"><div class="panel-card-body text-center"><div class="fw-bold fs-4">@Model.Summary.WaitingCustomerCount</div><div class="small text-muted">Müşteri bekliyor</div></div></div></div>
    <div class="col-6 col-md-2"><div class="panel-card h-100"><div class="panel-card-body text-center"><div class="fw-bold fs-4">@Model.Summary.ResolvedThisMonthCount</div><div class="small text-muted">Bu ay çözüldü</div></div></div></div>
</div>

@if (Model.AttentionItems.Any())
{
    <div class="panel-card mb-4 border-warning">
        <div class="panel-card-header"><h3 class="h6 mb-0">Dikkat gerektiren talepler</h3></div>
        <div class="panel-card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead><tr><th>No</th><th>İşletme</th><th>Konu</th><th>Öncelik</th><th>Neden</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var a in Model.AttentionItems)
                    {
                        <tr>
                            <td>@a.TicketNumber</td>
                            <td>@a.BusinessName</td>
                            <td>@a.Subject</td>
                            <td><span class="badge @SupportTicketDisplayHelper.GetPriorityBadgeClass(a.Priority)">@SupportTicketDisplayHelper.GetPriorityLabel(a.Priority)</span></td>
                            <td class="small">@a.Reason</td>
                            <td><a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-outline-warning">Aç</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<form method="get" class="panel-card mb-4">
    <div class="panel-card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small">İşletme</label>
                <select name="businessId" asp-items="Model.BusinessOptions" class="form-select form-select-sm"></select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Durum</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Tümü</option>
                    @foreach (var s in SupportTicketDisplayHelper.AllowedStatuses)
                    {
                        <option value="@s" selected="@(Model.Status == s)">@SupportTicketDisplayHelper.GetStatusLabel(s)</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Kategori</label>
                <select name="category" class="form-select form-select-sm">
                    <option value="">Tümü</option>
                    @foreach (var c in SupportTicketDisplayHelper.AllowedCategories)
                    {
                        <option value="@c" selected="@(Model.Category == c)">@SupportTicketDisplayHelper.GetCategoryLabel(c)</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Öncelik</label>
                <select name="priority" class="form-select form-select-sm">
                    <option value="">Tümü</option>
                    @foreach (var p in SupportTicketDisplayHelper.AllowedPriorities)
                    {
                        <option value="@p" selected="@(Model.Priority == p)">@SupportTicketDisplayHelper.GetPriorityLabel(p)</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Atama</label>
                <select name="assigned" class="form-select form-select-sm">
                    <option value="">Tümü</option>
                    <option value="assigned" selected="@(Model.Assigned == "assigned")">Atanmış</option>
                    <option value="unassigned" selected="@(Model.Assigned == "unassigned")">Atanmamış</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Ara</label>
                <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm" />
            </div>
            <div class="col-12"><button type="submit" class="btn btn-sm btn-outline-primary">Filtrele</button></div>
        </div>
    </div>
</form>

<div class="panel-card">
    <div class="panel-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>No</th><th>İşletme</th><th>Konu</th><th>Kategori</th><th>Öncelik</th><th>Durum</th><th>Son mesaj</th><th>Atanan</th><th></th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">Kayıt yok.</td></tr>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="small fw-semibold">@item.TicketNumber</td>
                            <td class="small">@item.BusinessName</td>
                            <td>@item.Subject</td>
                            <td class="small">@SupportTicketDisplayHelper.GetCategoryLabel(item.Category)</td>
                            <td><span class="badge @SupportTicketDisplayHelper.GetPriorityBadgeClass(item.Priority)">@SupportTicketDisplayHelper.GetPriorityLabel(item.Priority)</span></td>
                            <td><span class="badge @SupportTicketDisplayHelper.GetStatusBadgeClass(item.Status)">@SupportTicketDisplayHelper.GetStatusLabel(item.Status)</span></td>
                            <td class="small text-muted">@SupportTicketDisplayHelper.GetLastMessageText(item.LastMessageAtUtc, item.LastMessageByRole)</td>
                            <td class="small">@(item.AssignedAdminEmail ?? "—")</td>
                            <td><a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Detay</a></td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
