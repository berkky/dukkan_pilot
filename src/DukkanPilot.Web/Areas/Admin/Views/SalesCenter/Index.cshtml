@model DukkanPilot.Web.Areas.Admin.Models.SalesCenterViewModel
@{
    ViewData["Title"] = "Satış ve Demo Merkezi";
}

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h2 class="h4 mb-1">Satış ve Demo Merkezi</h2>
        <p class="text-muted mb-0">Demo-ready işletmeleri ve satış/operasyon akışını buradan takip edin.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a href="/Demo" class="btn btn-outline-primary btn-sm" target="_blank" rel="noopener">Landing Demo</a>
        <a href="/Admin/ValueCalculator" class="btn btn-outline-primary btn-sm">Değer Hesaplayıcı</a>
        <a href="/Admin/HelpCenter/Article/demo-gorusmesi" class="btn btn-outline-secondary btn-sm">Demo rehberi</a>
    </div>
</div>

<div class="alert alert-info mb-4">
    <strong>Satış görüşmesi ipucu:</strong>
    Değer hesaplayıcı ile temkinli/temel/iddialı senaryoları gösterin.
    Sonuçlar garanti değildir — varsayım tabanlıdır.
    <a href="/Admin/ValueCalculator" class="alert-link">Satış değer hesaplayıcıyı aç</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl">
        <div class="stat-card h-100"><div class="stat-label">Toplam İşletme</div><div class="stat-value">@Model.TotalBusinesses</div></div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="stat-card h-100"><div class="stat-label">Aktif</div><div class="stat-value text-success">@Model.ActiveBusinesses</div></div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="stat-card h-100"><div class="stat-label">Trial</div><div class="stat-value">@Model.TrialBusinesses</div></div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="stat-card h-100"><div class="stat-label">Abonelik bitmek üzere</div><div class="stat-value text-warning">@Model.ExpiringSoonBusinesses</div></div>
    </div>
    <div class="col-sm-6 col-xl">
        <div class="stat-card h-100"><div class="stat-label">Demo-ready</div><div class="stat-value text-primary">@Model.DemoReadyBusinesses</div></div>
    </div>
    <div class="col-sm-6 col-xl">
        <a href="/Admin/Onboarding" class="text-decoration-none">
            <div class="stat-card h-100 border-success">
                <div class="stat-label">Onboarding-ready</div>
                <div class="stat-value text-success">@Model.OnboardingReadyBusinesses</div>
                <small class="text-muted">Kurulum Takibi</small>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl">
        <a href="/Admin/CustomerSuccess" class="text-decoration-none">
            <div class="stat-card h-100 border-dark">
                <div class="stat-label">Customer health</div>
                <div class="stat-value text-dark">@Model.HealthyBusinesses</div>
                <small class="text-muted">@Model.UpgradeOpportunityCount upgrade fırsatı</small>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl">
        <a href="/Admin/SalesRequests" class="text-decoration-none">
            <div class="stat-card h-100 border-primary">
                <div class="stat-label">Satış Talepleri</div>
                <div class="stat-value text-primary">→</div>
                <small class="text-muted">Demo / plan / yükseltme pipeline</small>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl">
        <a href="/Admin/Billing" class="text-decoration-none">
            <div class="stat-card h-100 border-warning">
                <div class="stat-label">Billing operasyon</div>
                <div class="stat-value text-warning">@Model.BillingOverdueCount gecikmiş</div>
                <small class="text-muted">Açık: @Model.BillingOpenAmount.ToString("N2") ₺ · Bu ay: @Model.BillingPaidThisMonth.ToString("N2") ₺</small>
            </div>
        </a>
    </div>
</div>

<div class="panel-card mb-4">
    <div class="panel-card-header"><h3 class="h6 mb-0">Müşteriye 7 adımda demo</h3></div>
    <div class="panel-card-body">
        <ol class="mb-3 small">
            <li>Public QR menüyü aç (`/m/{slug}`)</li>
            <li>Sepet + kampanya indirimini göster</li>
            <li>Sipariş confirmation/tracking</li>
            <li>Kitchen’da durum ilerlet</li>
            <li>CRM + raporlar</li>
            <li>Bildirim / Audit Log</li>
            <li>Go-Live ve ücretsiz kayıt CTA</li>
        </ol>
        <div class="d-flex flex-wrap gap-2">
            <a href="/Admin/Businesses" class="btn btn-sm btn-outline-primary">İşletmeler</a>
            <a href="/Admin/Notifications" class="btn btn-sm btn-outline-warning">Bildirimler</a>
            <a href="/Admin/AuditLogs" class="btn btn-sm btn-outline-dark">Aktivite Logları</a>
            <a href="/m/demo-kafe" class="btn btn-sm btn-outline-success" target="_blank" rel="noopener">Demo Kafe Menü</a>
        </div>
        <p class="small text-muted mb-0 mt-3">Panel şifreleri public sayfalarda paylaşılmaz.</p>
    </div>
</div>

<div class="panel-card mb-4 border-info">
    <div class="panel-card-header"><h3 class="h6 mb-0">Satış öncesi güven evrakları</h3></div>
    <div class="panel-card-body">
        <p class="small text-muted mb-3">Taslak legal sayfalar ve operasyon dokümanları — kesin KVKK uyumluluk iddiası yoktur.</p>
        <div class="d-flex flex-wrap gap-2">
            <a href="/Trust" class="btn btn-sm btn-primary" target="_blank" rel="noopener">Trust Center</a>
            <a href="/Privacy" class="btn btn-sm btn-outline-secondary" target="_blank" rel="noopener">Privacy</a>
            <a href="/Kvkk" class="btn btn-sm btn-outline-secondary" target="_blank" rel="noopener">KVKK</a>
            <a href="/Admin/Operations" class="btn btn-sm btn-outline-dark">Operasyon Merkezi</a>
        </div>
        <p class="small text-muted mb-0 mt-3">Repo: <code>docs/DATABASE_BACKUP_AND_RECOVERY.md</code>, <code>docs/PRODUCT_POSITIONING.md</code>, <code>docs/LEGAL_READINESS_CHECKLIST.md</code></p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="panel-card">
            <div class="panel-card-header"><h3 class="h6 mb-0">Demo-ready işletmeler</h3></div>
            <div class="panel-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>İşletme</th>
                                <th>Sağlık</th>
                                <th>Ürün</th>
                                <th>Sipariş</th>
                                <th>Kampanya</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.DemoReadyList.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted py-4">Henüz demo-ready işletme yok.</td></tr>
                        }
                        else
                        {
                            foreach (var b in Model.DemoReadyList)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@b.BusinessName</div>
                                        <a class="small" href="@b.PublicMenuUrl" target="_blank" rel="noopener">/m/@b.Slug</a>
                                    </td>
                                    <td><span class="badge @b.HealthBadgeClass">@b.HealthScore · @b.HealthLabel</span></td>
                                    <td>@b.ActiveProductCount</td>
                                    <td>@b.OrderCount</td>
                                    <td>@b.CampaignCount</td>
                                    <td class="text-end">
                                        <a href="/Admin/Businesses/Details/@b.BusinessId" class="btn btn-sm btn-outline-secondary">Detay</a>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="panel-card">
            <div class="panel-card-header"><h3 class="h6 mb-0">Dikkat gerekenler</h3></div>
            <div class="panel-card-body p-0">
                <ul class="list-group list-group-flush">
                    @if (!Model.NeedsAttentionList.Any())
                    {
                        <li class="list-group-item text-muted">Platform sağlıklı görünüyor.</li>
                    }
                    else
                    {
                        foreach (var b in Model.NeedsAttentionList)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <div class="fw-semibold small">@b.BusinessName</div>
                                    <div class="text-muted small">@b.AttentionReason</div>
                                </div>
                                <a href="/Admin/Businesses/Details/@b.BusinessId" class="btn btn-sm btn-outline-secondary">Detay</a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-lg-7">
        <div class="panel-card">
            <div class="panel-card-header d-flex justify-content-between align-items-center">
                <h3 class="h6 mb-0">Onboarding-ready işletmeler</h3>
                <a href="/Admin/Onboarding" class="btn btn-sm btn-outline-primary">Kurulum Takibi</a>
            </div>
            <div class="panel-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>İşletme</th>
                                <th>Onboarding</th>
                                <th>Ürün</th>
                                <th>Sipariş</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.OnboardingReadyList.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">Henüz yayına hazır / canlı işletme yok.</td></tr>
                        }
                        else
                        {
                            foreach (var b in Model.OnboardingReadyList)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@b.BusinessName</div>
                                        <span class="small text-muted">@b.Slug</span>
                                    </td>
                                    <td><span class="badge @b.HealthBadgeClass">@b.HealthScore · @b.HealthLabel</span></td>
                                    <td>@b.ActiveProductCount</td>
                                    <td>@b.OrderCount</td>
                                    <td class="text-end">
                                        <a href="/Admin/Onboarding/Details/@b.BusinessId" class="btn btn-sm btn-outline-primary">Kurulum</a>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="panel-card">
            <div class="panel-card-header"><h3 class="h6 mb-0">Won SalesRequests → onboarding</h3></div>
            <div class="panel-card-body p-0">
                <ul class="list-group list-group-flush">
                    @if (!Model.WonHandoffs.Any())
                    {
                        <li class="list-group-item text-muted small">Won talep yok.</li>
                    }
                    else
                    {
                        foreach (var w in Model.WonHandoffs)
                        {
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between gap-2">
                                    <div>
                                        <div class="fw-semibold small">#@w.SalesRequestId · @w.ContactName</div>
                                        <div class="text-muted small">@(w.BusinessName ?? "İşletme adı yok")</div>
                                        @if (w.OnboardingScore is int sc)
                                        {
                                            <span class="badge @(w.OnboardingBadgeClass ?? "bg-secondary")">@w.OnboardingStatusLabel · @sc</span>
                                        }
                                        @if (w.SuccessScore is int hc)
                                        {
                                            <span class="badge @(w.SuccessBadgeClass ?? "bg-secondary")">Health · @hc @(w.SuccessStatusLabel)</span>
                                        }
                                        else if (w.BusinessId is null)
                                        {
                                            <span class="small text-warning">İşletme bağlanmamış</span>
                                        }
                                    </div>
                                    <div class="text-nowrap">
                                        <a href="/Admin/SalesRequests/Details/@w.SalesRequestId" class="btn btn-sm btn-outline-secondary">Talep</a>
                                        @if (w.BusinessId is int bid)
                                        {
                                            <a href="/Admin/Onboarding/Details/@bid" class="btn btn-sm btn-outline-primary">Kurulum</a>
                                        }
                                    </div>
                                </div>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="panel-card mt-4">
    <div class="panel-card-header d-flex justify-content-between align-items-center">
        <h3 class="h6 mb-0">Customer health özeti</h3>
        <a href="/Admin/CustomerSuccess" class="btn btn-sm btn-outline-dark">Customer Success</a>
    </div>
    <div class="panel-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>İşletme</th>
                        <th>Health</th>
                        <th>Sipariş</th>
                        <th>Ürün</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.HealthyList.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Henüz sağlıklı / growth-ready işletme yok.</td></tr>
                }
                else
                {
                    foreach (var b in Model.HealthyList)
                    {
                        <tr>
                            <td><div class="fw-semibold">@b.BusinessName</div><div class="small text-muted">@b.Slug</div></td>
                            <td><span class="badge @(b.SuccessBadgeClass ?? b.HealthBadgeClass)">@(b.SuccessScore ?? b.HealthScore) · @(b.SuccessLabel ?? b.HealthLabel)</span></td>
                            <td>@b.OrderCount</td>
                            <td>@b.ActiveProductCount</td>
                            <td class="text-end"><a href="/Admin/CustomerSuccess/Details/@b.BusinessId" class="btn btn-sm btn-outline-dark">Health</a></td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
