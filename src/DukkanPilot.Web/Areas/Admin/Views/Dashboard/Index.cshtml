@model AdminDashboardViewModel
@using System.Globalization
@{
    ViewData["Title"] = "SaaS Yönetim Merkezi";
    ViewData["Subtitle"] = "Platform genelindeki işletme, abonelik ve kullanım durumunu takip edin.";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
    string Money(decimal amount) => amount.ToString("N2", culture) + " ₺";
    var sub = Model.Subscriptions;
    var subTotal = sub.TrialSubscriptions + sub.ActiveSubscriptions + sub.ExpiredSubscriptions
        + sub.CancelledSubscriptions + sub.ExpiringSoonSubscriptions + sub.BusinessesWithoutSubscription;
    int SubPercent(int count) => subTotal > 0 ? (int)Math.Round(count * 100.0 / subTotal) : 0;
}

<div class="page-header mb-4">
    <h2 class="h4 mb-1">SaaS Yönetim Merkezi</h2>
    <p class="text-muted mb-0">Platform genelindeki işletme, abonelik ve kullanım durumunu takip edin.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-4">
        <a href="/Admin/SalesRequests?status=New" class="text-decoration-none">
            <div class="panel-card h-100 border-primary mb-0">
                <div class="panel-card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small mb-1">Satış Talepleri</div>
                            <div class="h4 mb-1 text-primary">@Model.NewSalesRequestCount yeni</div>
                            <div class="small text-muted">@Model.OpenSalesRequestCount açık talep</div>
                        </div>
                        <span class="fs-4">📨</span>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a href="/Admin/Onboarding" class="text-decoration-none">
            <div class="panel-card h-100 border-warning mb-0">
                <div class="panel-card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small mb-1">Onboarding riski</div>
                            <div class="h4 mb-1 text-warning">@Model.OnboardingAtRiskCount işletme</div>
                            <div class="small text-muted">@Model.OnboardingLiveCount canlı · Kurulum Takibi</div>
                        </div>
                        <span class="fs-4">🧭</span>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a href="/Admin/CustomerSuccess" class="text-decoration-none">
            <div class="panel-card h-100 border-danger mb-0">
                <div class="panel-card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small mb-1">Customer Success riski</div>
                            <div class="h4 mb-1 text-danger">@Model.CustomerSuccessAtRiskCount işletme</div>
                            <div class="small text-muted">@Model.CustomerSuccessHealthyCount sağlıklı · Retention takibi</div>
                        </div>
                        <span class="fs-4">💚</span>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a href="/Admin/Quality" class="text-decoration-none">
            <div class="panel-card h-100 border-dark mb-0">
                <div class="panel-card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-muted small mb-1">Kalite Merkezi</div>
                            <div class="h4 mb-1">Release gate</div>
                            <div class="small text-muted">Smoke / SEO / security headers</div>
                        </div>
                        <span class="fs-4">✅</span>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

@if (Model.CriticalNotifications.Count > 0)
{
    <div class="panel-card mb-4 border-warning">
        <div class="panel-card-header d-flex justify-content-between align-items-center">
            <h3 class="h6 mb-0">Kritik Bildirimler</h3>
            <a href="/Admin/Notifications" class="btn btn-sm btn-outline-warning">Tümünü Gör</a>
        </div>
        <div class="panel-card-body p-0">
            <ul class="list-group list-group-flush">
                @foreach (var n in Model.CriticalNotifications)
                {
                    <li class="list-group-item">
                        <div class="fw-semibold small">@n.Title</div>
                        <div class="text-muted small">@n.Message</div>
                    </li>
                }
            </ul>
        </div>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Toplam İşletme</div>
            <div class="stat-value">@Model.Platform.TotalBusinesses</div>
            <small class="text-muted">@Model.Platform.ActiveBusinesses aktif · @Model.Platform.PassiveBusinesses pasif</small>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Toplam Platform Cirosu</div>
            <div class="stat-value">@Money(Model.Platform.TotalRevenue)</div>
            <small class="text-muted">Bugün: @Money(Model.Platform.TodayRevenue)</small>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Toplam Sipariş</div>
            <div class="stat-value">@Model.Platform.TotalOrders</div>
            <small class="text-muted">Son 7 gün: @Model.Platform.Last7DaysOrders</small>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card h-100">
            <div class="stat-label">Aktif Abonelik</div>
            <div class="stat-value">@sub.ActiveSubscriptions</div>
            <small class="text-muted">@sub.ExpiredSubscriptions süresi dolmuş</small>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-md-4 col-xl-2">
        <div class="stat-card h-100 py-3">
            <div class="stat-label small">Toplam Kullanıcı</div>
            <div class="stat-value fs-4">@Model.Platform.TotalUsers</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-4 col-xl-2">
        <div class="stat-card h-100 py-3">
            <div class="stat-label small">İşletme Sahibi</div>
            <div class="stat-value fs-4">@Model.Platform.BusinessOwnersCount</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-4 col-xl-2">
        <div class="stat-card h-100 py-3">
            <div class="stat-label small">Personel</div>
            <div class="stat-value fs-4">@Model.Platform.StaffUsersCount</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-4 col-xl-2">
        <div class="stat-card h-100 py-3">
            <div class="stat-label small">Bugünkü Sipariş</div>
            <div class="stat-value fs-4">@Model.Platform.TodayOrders</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-4 col-xl-2">
        <div class="stat-card h-100 py-3">
            <div class="stat-label small">Bu Ay Ciro</div>
            <div class="stat-value fs-5">@Money(Model.Platform.ThisMonthRevenue)</div>
        </div>
    </div>
    <div class="col-sm-6 col-md-4 col-xl-2">
        <div class="stat-card h-100 py-3">
            <div class="stat-label small">Bu Ay Sipariş</div>
            <div class="stat-value fs-4">@Model.Platform.ThisMonthOrders</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="panel-card h-100">
            <div class="panel-card-header">
                <h3 class="h6 mb-0">Abonelik Durumu</h3>
            </div>
            <div class="panel-card-body">
                @{
                    var subItems = new (string Label, int Count, string Badge)[]
                    {
                        ("Deneme (Trial)", sub.TrialSubscriptions, "bg-info text-dark"),
                        ("Aktif", sub.ActiveSubscriptions, "bg-success"),
                        ("Süresi Dolmuş", sub.ExpiredSubscriptions, "bg-danger"),
                        ("İptal", sub.CancelledSubscriptions, "bg-secondary"),
                        ("7 Gün İçinde Bitecek", sub.ExpiringSoonSubscriptions, "bg-warning text-dark"),
                        ("Aboneliği Olmayan", sub.BusinessesWithoutSubscription, "bg-dark")
                    };
                }
                @foreach (var item in subItems)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span>@item.Label</span>
                            <span class="badge @item.Badge">@item.Count</span>
                        </div>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar @item.Badge" role="progressbar"
                                 style="width: @(SubPercent(item.Count))%"
                                 aria-valuenow="@item.Count" aria-valuemin="0" aria-valuemax="@subTotal"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="panel-card h-100">
            <div class="panel-card-header">
                <h3 class="h6 mb-0">Plan Dağılımı</h3>
            </div>
            <div class="panel-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Plan</th>
                                <th class="text-end">İşletme</th>
                                <th class="text-end">Aktif Abonelik</th>
                                <th class="text-end">Potansiyel Gelir</th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.PlanDistribution.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">Plan kaydı yok.</td></tr>
                        }
                        else
                        {
                            foreach (var plan in Model.PlanDistribution)
                            {
                                <tr>
                                    <td class="fw-semibold">@plan.PlanName</td>
                                    <td class="text-end">@plan.BusinessCount</td>
                                    <td class="text-end">@plan.ActiveSubscriptionCount</td>
                                    <td class="text-end">@Money(plan.MonthlyPotentialRevenue)</td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="panel-card">
            <div class="panel-card-header d-flex justify-content-between align-items-center">
                <h3 class="h6 mb-0">En Aktif İşletmeler (Top 10)</h3>
                <a href="/Admin/Businesses" class="btn btn-sm btn-outline-primary">Tümünü Gör</a>
            </div>
            <div class="panel-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>İşletme</th>
                                <th>Slug</th>
                                <th class="text-end">Sipariş</th>
                                <th class="text-end">Ciro</th>
                                <th class="text-end">Ürün</th>
                                <th>Plan</th>
                                <th>Durum</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.TopActiveBusinesses.Any())
                        {
                            <tr><td colspan="8" class="text-center text-muted py-3">Veri yok.</td></tr>
                        }
                        else
                        {
                            foreach (var b in Model.TopActiveBusinesses)
                            {
                                <tr>
                                    <td class="fw-semibold">@b.BusinessName</td>
                                    <td><code>@b.Slug</code></td>
                                    <td class="text-end">@b.OrderCount</td>
                                    <td class="text-end">@Money(b.Revenue)</td>
                                    <td class="text-end">@b.ActiveProductsCount</td>
                                    <td>@b.CurrentPlanName</td>
                                    <td><span class="badge @b.SubscriptionStatusBadgeClass">@b.SubscriptionStatus</span></td>
                                    <td class="text-end">
                                        <a href="/Admin/Businesses/Details/@b.BusinessId" class="btn btn-sm btn-outline-secondary">Detay</a>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel-card h-100">
            <div class="panel-card-header">
                <h3 class="h6 mb-0">Hızlı Aksiyonlar</h3>
            </div>
            <div class="panel-card-body d-grid gap-2">
                <a href="/Admin/Operations" class="btn btn-primary">Operasyon Merkezi</a>
                <p class="small text-muted mb-0">Release, migration ve backup kontrolü için Operasyon Merkezi</p>
                <a href="/Admin/SalesCenter" class="btn btn-outline-primary">Satış ve Demo Merkezi</a>
                <a href="/Admin/SalesRequests" class="btn btn-outline-primary">Satış Talepleri</a>
                <a href="/Admin/Businesses" class="btn btn-outline-primary">İşletmeler</a>
                <a href="/Admin/Notifications" class="btn btn-outline-warning">Bildirimler</a>
                <a href="/Admin/AuditLogs" class="btn btn-outline-dark">Aktivite Logları</a>
                <a href="/Admin/SubscriptionPlans" class="btn btn-outline-secondary">Abonelik Planları</a>
                <a href="/Admin/SubscriptionPlans/Create" class="btn btn-outline-secondary">Yeni Plan</a>
                <a href="/Admin/Businesses" class="btn btn-outline-info">Abonelik Yönetimi (İşletme Listesi)</a>
                <a href="/health" class="btn btn-outline-dark" target="_blank" rel="noopener">Sistem Durumu (/health)</a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="panel-card">
            <div class="panel-card-header">
                <h3 class="h6 mb-0">Riskli İşletmeler</h3>
            </div>
            <div class="panel-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>İşletme</th>
                                <th>Risk</th>
                                <th class="text-end">Son Sipariş</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.RiskyBusinesses.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">Şu an riskli işletme görünmüyor. Abonelik, menü eksikleri veya düşük aktivite oluşursa burada listelenir.</td></tr>
                        }
                        else
                        {
                            foreach (var r in Model.RiskyBusinesses)
                            {
                                <tr>
                                    <td class="fw-semibold">@r.BusinessName</td>
                                    <td><span class="badge @r.RiskBadgeClass">@r.RiskReason</span></td>
                                    <td class="text-end small text-muted">
                                        @(r.LastOrderAt.HasValue ? r.LastOrderAt.Value.ToLocalTime().ToString("dd.MM.yyyy") : "-")
                                    </td>
                                    <td class="text-end">
                                        <a href="/Admin/Businesses/Details/@r.BusinessId" class="btn btn-sm btn-outline-secondary">Detay</a>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="panel-card">
            <div class="panel-card-header">
                <h3 class="h6 mb-0">Son Kayıt Olan İşletmeler</h3>
            </div>
            <div class="panel-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>İşletme</th>
                                <th>Kayıt</th>
                                <th>Plan</th>
                                <th>Durum</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                        @if (!Model.RecentBusinesses.Any())
                        {
                            <tr><td colspan="5" class="text-center text-muted py-3">Kayıt yok.</td></tr>
                        }
                        else
                        {
                            foreach (var b in Model.RecentBusinesses)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@b.BusinessName</div>
                                        @if (!string.IsNullOrEmpty(b.OwnerEmail))
                                        {
                                            <small class="text-muted">@b.OwnerEmail</small>
                                        }
                                    </td>
                                    <td class="small">@b.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                    <td>@b.CurrentPlanName</td>
                                    <td><span class="badge @b.SubscriptionStatusBadgeClass">@b.SubscriptionStatus</span></td>
                                    <td class="text-end">
                                        <a href="/Admin/Businesses/Details/@b.BusinessId" class="btn btn-sm btn-outline-secondary">Detay</a>
                                    </td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
