<header class="admin-navbar d-flex align-items-center justify-content-between px-4 py-3">
    <div>
        <h1 class="page-title h5 mb-0">@ViewData["Title"]</h1>
        @if (ViewData["Subtitle"] is string subtitle)
        {
            <p class="text-muted small mb-0">@subtitle</p>
        }
    </div>
    <div class="d-flex align-items-center gap-2">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <span class="badge bg-primary d-none d-md-inline">@User.Identity.Name</span>
            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-primary">Çıkış</button>
            </form>
        }
    </div>
</header>
