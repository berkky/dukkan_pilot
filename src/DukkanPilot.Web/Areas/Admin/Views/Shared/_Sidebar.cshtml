@{
    var activeMenu = ViewData["ActiveMenu"] as string ?? string.Empty;
}

<aside class="admin-sidebar">
    <div class="sidebar-brand px-3 py-4">
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-decoration-none">
            <span class="brand-icon">DP</span>
            <span class="brand-text">DükkanPilot</span>
        </a>
        <small class="d-block text-muted mt-1 ps-1">Yönetim Paneli</small>
    </div>

    <nav class="sidebar-nav px-2">
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link @(activeMenu == "dashboard" ? "active" : "")"
                   asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <span class="nav-icon">📊</span> SaaS Yönetim Merkezi
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeMenu == "sales-center" ? "active" : "")"
                   href="/Admin/SalesCenter">
                    <span class="nav-icon">🎯</span> Satış Merkezi
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeMenu == "sales-requests" ? "active" : "")"
                   href="/Admin/SalesRequests">
                    <span class="nav-icon">📨</span> Satış Talepleri
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeMenu == "operations" ? "active" : "")"
                   href="/Admin/Operations">
                    <span class="nav-icon">🛠️</span> Operasyon Merkezi
                </a>
            </li>

            <li class="sidebar-divider">İşletmeler</li>
            <li class="nav-item">
                <a class="nav-link @(activeMenu == "businesses" ? "active" : "")"
                   href="/Admin/Businesses">
                    <span class="nav-icon">🏢</span> İşletmeler
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeMenu == "businesses-create" ? "active" : "")"
                   href="/Admin/Businesses/Create">
                    <span class="nav-icon">➕</span> Yeni İşletme
                </a>
            </li>

            <li class="sidebar-divider">Abonelik</li>
            <li class="nav-item">
                <a class="nav-link @(activeMenu == "plans" ? "active" : "")"
                   href="/Admin/SubscriptionPlans">
                    <span class="nav-icon">💳</span> Abonelik Planları
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeMenu == "plans-create" ? "active" : "")"
                   href="/Admin/SubscriptionPlans/Create">
                    <span class="nav-icon">➕</span> Yeni Plan
                </a>
            </li>

            <li class="sidebar-divider">İzleme</li>
            <li class="nav-item">
                <a class="nav-link @(activeMenu == "notifications" ? "active" : "")"
                   href="/Admin/Notifications">
                    <span class="nav-icon">🔔</span> Bildirimler
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(activeMenu == "audit-logs" ? "active" : "")"
                   href="/Admin/AuditLogs">
                    <span class="nav-icon">🧾</span> Aktivite Logları
                </a>
            </li>
        </ul>
    </nav>

    <div class="sidebar-footer px-3 py-3 mt-auto">
        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-light btn-sm w-100">
            ← Ana Sayfa
        </a>
    </div>
</aside>
