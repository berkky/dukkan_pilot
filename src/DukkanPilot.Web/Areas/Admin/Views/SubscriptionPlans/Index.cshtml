@model IEnumerable<SubscriptionPlanListViewModel>
@using System.Globalization
@{
    ViewData["Title"] = "Abonelik Planları";
    ViewData["Subtitle"] = "Plan tanımlarını yönetin";
    var culture = CultureInfo.GetCultureInfo("tr-TR");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-1">Abonelik Planları</h2>
        <p class="text-muted mb-0">Free, Starter, Pro ve diğer planlar</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">+ Yeni Plan</a>
</div>

<div class="panel-card">
    <div class="panel-card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Plan Adı</th>
                        <th>Fiyat</th>
                        <th>Limitler</th>
                        <th class="text-end">Aktif İşletme</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Henüz plan kaydı yok.</td>
                    </tr>
                }
                else
                {
                    foreach (var plan in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@plan.Name</div>
                                @if (!string.IsNullOrWhiteSpace(plan.Description))
                                {
                                    <small class="text-muted">@plan.Description</small>
                                }
                            </td>
                            <td>
                                <span class="fw-semibold">@plan.Price.ToString("N2", culture) ₺</span>
                                <small class="d-block text-muted">/ ay</small>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border me-1">@plan.MaxProducts ürün</span>
                                <span class="badge bg-light text-dark border">@plan.MaxCampaigns kampanya</span>
                            </td>
                            <td class="text-end">
                                <span class="fw-semibold">@plan.ActiveBusinessCount</span>
                                @if (plan.HasActiveSubscriptions)
                                {
                                    <small class="d-block text-warning">Aktif abonelik var</small>
                                }
                            </td>
                            <td>
                                @if (plan.IsActive)
                                {
                                    <span class="badge bg-success">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <a asp-action="Details" asp-route-id="@plan.Id" class="btn btn-sm btn-outline-secondary">Detay</a>
                                <a asp-action="Edit" asp-route-id="@plan.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                                @if (plan.HasActiveSubscriptions)
                                {
                                    <span class="btn btn-sm btn-outline-danger disabled" title="Aktif abonelikte kullanılan plan pasife alınırken dikkatli olun.">Sil</span>
                                }
                                else
                                {
                                    <a asp-action="Delete" asp-route-id="@plan.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
