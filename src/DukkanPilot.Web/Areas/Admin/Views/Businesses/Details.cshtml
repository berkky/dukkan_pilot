@model BusinessDetailsViewModel
@{
    ViewData["Title"] = "İşletme Detayı";
    ViewData["Subtitle"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="h4 mb-1">@Model.Name</h2>
        <p class="text-muted mb-0"><code>@Model.Slug</code></p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Düzenle</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Listeye Dön</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="panel-card h-100">
            <div class="panel-card-header"><h3 class="h6 mb-0">İşletme Bilgileri</h3></div>
            <div class="panel-card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Id</dt><dd class="col-sm-8">@Model.Id</dd>
                    <dt class="col-sm-4">Telefon</dt><dd class="col-sm-8">@(Model.Phone ?? "-")</dd>
                    <dt class="col-sm-4">Logo</dt><dd class="col-sm-8">@(Model.LogoUrl ?? "-")</dd>
                    <dt class="col-sm-4">Durum</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsActive) { <span class="badge bg-success">Aktif</span> }
                        else { <span class="badge bg-secondary">Pasif</span> }
                    </dd>
                    <dt class="col-sm-4">Oluşturulma</dt><dd class="col-sm-8">@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="panel-card h-100">
            <div class="panel-card-header"><h3 class="h6 mb-0">Ayarlar & Abonelik</h3></div>
            <div class="panel-card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">WhatsApp</dt><dd class="col-sm-8">@(Model.WhatsAppNumber ?? "-")</dd>
                    <dt class="col-sm-4">Tema</dt>
                    <dd class="col-sm-8">
                        <span class="d-inline-block rounded border" style="width:1.25rem;height:1.25rem;background:@Model.ThemeColor"></span>
                        @Model.ThemeColor
                    </dd>
                    <dt class="col-sm-4">Para Birimi</dt><dd class="col-sm-8">@Model.Currency</dd>
                    <dt class="col-sm-4">Aktif Plan</dt><dd class="col-sm-8">@Model.ActivePlanName</dd>
                    <dt class="col-sm-4">Abonelik Durumu</dt><dd class="col-sm-8">@Model.SubscriptionStatus</dd>
                    <dt class="col-sm-4">Başlangıç</dt>
                    <dd class="col-sm-8">@(Model.SubscriptionStartDate?.ToLocalTime().ToString("dd.MM.yyyy") ?? "-")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="panel-card">
            <div class="panel-card-header"><h3 class="h6 mb-0">İstatistikler</h3></div>
            <div class="panel-card-body">
                <div class="row g-3 text-center">
                    <div class="col-6 col-md-3"><div class="stat-card"><div class="stat-label">Kategori</div><div class="stat-value">@Model.CategoryCount</div></div></div>
                    <div class="col-6 col-md-3"><div class="stat-card"><div class="stat-label">Ürün</div><div class="stat-value">@Model.ProductCount</div></div></div>
                    <div class="col-6 col-md-3"><div class="stat-card"><div class="stat-label">Müşteri</div><div class="stat-value">@Model.CustomerCount</div></div></div>
                    <div class="col-6 col-md-3"><div class="stat-card"><div class="stat-label">Sipariş</div><div class="stat-value">@Model.OrderCount</div></div></div>
                </div>
            </div>
        </div>
    </div>
</div>
