@model BusinessFormViewModel
@{
    ViewData["Title"] = "İşletme Düzenle";
    ViewData["Subtitle"] = Model.Name;
}

<div class="mb-4">
    <h2 class="h4 mb-1">İşletme Düzenle</h2>
    <p class="text-muted mb-0">@Model.Name</p>
</div>

<div class="panel-card">
    <div class="panel-card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            <input type="hidden" asp-for="Id" />
            <partial name="_FormFields" model="Model" />
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">Güncelle</button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
